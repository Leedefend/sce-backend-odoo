{
  "schema_version": "lowcode_customer_config_baseline_manifest.v1",
  "status": "guarded",
  "purpose": "Declare how customer-confirmed low-code configuration is promoted from runtime edits to the replayable smart_construction_custom baseline.",
  "module_boundary": {
    "owner_module": "smart_construction_custom",
    "owner_layer": "L3 customer module",
    "responsibility": "customer-confirmed menu, form, field, role, initialization, and visible-surface preferences that must survive fresh install, upgrade, daily-dev sync, and production deployment",
    "forbidden_responsibilities": [
      "platform low-code engine internals",
      "industry-standard defaults shared by all customers",
      "temporary developer_draft low-code experiments",
      "ordinary user UI-only preferences"
    ]
  },
  "promotion_rule": {
    "runtime_source_status": "tenant_runtime",
    "release_source_status": "product_release",
    "customer_confirmed_destination": "smart_construction_custom or an explicit customer module",
    "rule": "A low-code save is not a delivery baseline until the confirmed result is captured in a replayable module asset, migration, or idempotent initializer."
  },
  "extraction_assistant": {
    "schema_version": "lowcode_customer_config_baseline_candidate.v1",
    "make_target": "make verify.lowcode_config.customer_baseline.candidate",
    "script": "scripts/verify/lowcode_customer_config_baseline_candidate.py",
    "artifact": "artifacts/backend/lowcode_customer_config_baseline_candidate.json",
    "module_asset_draft_schema_version": "lowcode_customer_config_module_asset_draft.v1",
    "module_asset_draft_make_target": "make verify.lowcode_config.customer_module_asset.draft",
    "module_asset_draft_script": "scripts/verify/lowcode_customer_config_module_asset_draft.py",
    "module_asset_draft_artifact": "artifacts/backend/lowcode_customer_config_module_asset_draft.json",
    "acceptance_decision_schema_version": "lowcode_customer_config_acceptance_decisions.v1",
    "acceptance_decision_template_make_target": "make verify.lowcode_config.customer_module_asset.acceptance_template",
    "acceptance_decision_template_script": "scripts/verify/lowcode_customer_config_acceptance_decision_template.py",
    "acceptance_decision_template_artifact": "artifacts/backend/lowcode_customer_config_acceptance_decisions_template.json",
    "acceptance_apply_dry_run_make_target": "make verify.lowcode_config.customer_module_asset.acceptance_apply.dry_run",
    "acceptance_apply_script": "scripts/verify/lowcode_customer_config_apply_acceptance_decisions.py",
    "acceptance_apply_dry_run_artifact": "artifacts/backend/lowcode_customer_config_contracts_candidate.json",
    "accepted_module_asset_schema_version": "lowcode_customer_config_contracts.v1",
    "accepted_module_asset": "addons/smart_construction_custom/data/lowcode_customer_config_contracts_v1.json",
    "accepted_module_asset_replay_guard": "make verify.lowcode_config.customer_module_asset.replay.guard",
    "customer_module_asset_pipeline_make_target": "make verify.lowcode_config.customer_module_asset.pipeline",
    "customer_module_asset_release_hardening_guard_make_target": "make verify.lowcode_config.customer_module_asset.release_hardening.guard",
    "default_source_status_filter": [
      "tenant_runtime"
    ],
    "policy": "The candidate artifact and module asset draft are review evidence only. Accepted rows must be converted into smart_construction_custom assets, migrations, or an idempotent initializer before release."
  },
  "replayable_surfaces": [
    {
      "surface": "menu_preferences",
      "runtime_carriers": [
        "ui.business.config.contract.menu_orchestration",
        "ui.menu.config.policy"
      ],
      "baseline_carrier": "sc.product.policy menu_groups projected by sc.user.preference.initialization.apply_user_menu_preferences",
      "source_marker": "smart_construction_custom.user_menu_preference",
      "install_hook": "apply_user_preferences"
    },
    {
      "surface": "form_preferences",
      "runtime_carriers": [
        "ui.business.config.contract.view_orchestration",
        "ui.form.field.policy compatibility input"
      ],
      "baseline_carrier": "ui.business.config.contract records generated by sc.user.preference.initialization.apply_user_form_preferences",
      "source_markers": [
        "smart_construction_custom.partner_form_preference",
        "smart_construction_custom.user_form_preference"
      ],
      "install_hook": "apply_user_preferences"
    },
    {
      "surface": "user_data_baseline",
      "runtime_carriers": [
        "migration replay assets",
        "locked customer data manifests"
      ],
      "baseline_carrier": "smart_construction_custom/data/user_module_data_baseline_contract_v1.json and related user data manifests",
      "source_marker": "smart_construction_custom user data baseline",
      "install_hook": "apply_user_data_baseline"
    }
  ],
  "required_module_assets": [
    "addons/smart_construction_custom/models/user_preferences.py",
    "addons/smart_construction_custom/hooks.py",
    "addons/smart_construction_custom/data/user_preferences.xml",
    "addons/smart_construction_custom/data/user_menu_preferences.xml",
    "addons/smart_construction_custom/data/lowcode_customer_config_contracts_v1.json",
    "addons/smart_construction_custom/data/user_module_data_baseline_contract_v1.json"
  ],
  "required_guards": [
    "make verify.lowcode_config.boundary.guard",
    "make verify.lowcode_config.runtime_boundary.guard",
    "make verify.lowcode_config.customer_baseline.candidate",
    "make verify.lowcode_config.customer_module_asset.draft",
    "make verify.lowcode_config.customer_module_asset.acceptance_template",
    "make verify.lowcode_config.customer_module_asset.acceptance_apply.dry_run",
    "make verify.lowcode_config.customer_module_asset.pipeline",
    "make verify.lowcode_config.customer_module_asset.release_hardening.guard",
    "make verify.lowcode_config.customer_module_asset.replay.guard",
    "make verify.business_config.unit",
    "make verify.business_config.snapshot"
  ],
  "acceptance_policy": {
    "fresh_install": "post_init_hook must apply platform initialization, business policy, user data baseline, user menu preferences, user form preferences, and low-code source_status backfill.",
    "upgrade": "custom module migration must backfill explicit source_status for existing configuration contracts.",
    "runtime": "runtime low-code boundary guard must see protected configuration menus through extension/config sources and reject ordinary-user visibility of global low-code configuration entries.",
    "cross_environment": "business configuration snapshots are the handoff artifact for comparing local, daily-dev, prod-sim, and production customer configuration state."
  }
}
