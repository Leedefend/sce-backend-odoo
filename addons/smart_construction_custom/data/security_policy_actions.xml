        <!-- 旧系统高频入口兼容：仅作为客户侧原生菜单别名，权限沿用现有能力组。 -->
        <record id="action_legacy_entry_project_overview" model="ir.actions.act_window">
            <field name="name">项目总览</field>
            <field name="res_model">project.project</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="view_id" ref="smart_construction_core.view_project_project_kanban_dashboard"/>
            <field name="context">{'group_by': 'lifecycle_state'}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_project_read'))]"/>
        </record>
        <record id="action_legacy_entry_todo_activity" model="ir.actions.act_window">
            <field name="name">待办提醒</field>
            <field name="res_model">mail.activity</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="context">{'search_default_my_activities': 1}</field>
            <field name="groups_id" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="action_legacy_entry_construction_contract" model="ir.actions.act_window">
            <field name="name">施工合同</field>
            <field name="res_model">construction.contract</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('type', '=', 'out')]</field>
            <field name="context">{'default_type': 'out'}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read')), (4, ref('smart_construction_core.group_sc_cap_contract_user')), (4, ref('smart_construction_core.group_sc_cap_contract_manager'))]"/>
        </record>
        <record id="action_legacy_entry_supplier_contract" model="ir.actions.act_window">
            <field name="name">供货合同</field>
            <field name="res_model">construction.contract</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('type', '=', 'in')]</field>
            <field name="context">{'default_type': 'in'}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read')), (4, ref('smart_construction_core.group_sc_cap_contract_user')), (4, ref('smart_construction_core.group_sc_cap_contract_manager'))]"/>
