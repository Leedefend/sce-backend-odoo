<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_payment_request_tree" model="ir.ui.view">
            <field name="name">payment.request.tree</field>
            <field name="model">payment.request</field>
            <field name="arch" type="xml">
                <tree string="付款/收款申请" decoration-danger="is_overpay_risk">
                    <field name="name"/>
                    <field name="type"/>
                    <field name="project_id"/>
                    <field name="contract_id"/>
                    <field name="settlement_id"/>
                    <field name="settlement_amount_payable"/>
                    <field name="is_overpay_risk" invisible="1"/>
                    <field name="partner_id"/>
                    <field name="amount"/>
                    <field name="state"/>
                    <field name="date_request"/>
                </tree>
            </field>
        </record>

        <record id="view_payment_request_form" model="ir.ui.view">
            <field name="name">payment.request.form</field>
            <field name="model">payment.request</field>
            <field name="arch" type="xml">
                <form string="付款/收款申请">
                    <header>
                        <button name="action_submit" type="object" string="提交审批" class="btn-primary" invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')" groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_user"/>
                        <button name="validate_tier" type="object" string="审批通过" class="btn-primary" invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" type="object" string="审批驳回" invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_approve" type="object" string="批准" class="btn-secondary" invisible="state != 'submit' or validation_status != 'validated'" groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <button name="action_set_approved" type="object" string="批准" class="btn-secondary" invisible="state != 'approve'" groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <button name="action_done" type="object" string="完成" class="btn-secondary" invisible="state not in ['approve', 'approved']" groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <button name="action_cancel" type="object" string="取消" class="btn-secondary" invisible="state in ['done', 'cancel']" groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submit,approve,approved,done,cancel"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(smart_construction_core.action_payment_ledger)d"
                                    string="付款记录"
                                    type="action"
                                    class="oe_stat_button"
                                    context="{'default_payment_request_id': context.get('active_id'), 'search_default_payment_request_id': context.get('active_id')}"
                                    groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
                        </div>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="type"/>
                                <field name="project_id" options="{'no_create': True}"/>
                                <field name="contract_id" domain="[('project_id', '=', project_id)]"/>
                                <field name="settlement_id" domain="[('project_id', '=', project_id)]"/>
                            </group>
                            <group>
                                <field name="partner_id"/>
                                <field name="amount"/>
                                <field name="currency_id"/>
                                <field name="date_request"/>
                                <field name="paid_amount_total" readonly="1"/>
                                <field name="unpaid_amount" readonly="1"/>
                                <field name="is_fully_paid" readonly="1"/>
                            </group>
                        </group>
                        <group string="结算依据">
                            <field name="settlement_id" domain="[('state','=','approve'), ('project_id','=', project_id)]"/>
                            <field name="settlement_amount_total"
                                   readonly="1"
                                   modifiers="{'invisible': [['settlement_id', '=', False]]}"/>
                            <field name="settlement_paid_amount"
                                   readonly="1"
                                   modifiers="{'invisible': [['settlement_id', '=', False]]}"/>
                            <field name="settlement_amount_payable"
                                   readonly="1"
                                   modifiers="{'invisible': [['settlement_id', '=', False]]}"/>
                            <field name="settlement_remaining_amount"
                                   readonly="1"
                                   modifiers="{'invisible': [['settlement_id', '=', False], ['settlement_amount_insufficient', '=', True]]}"/>
                            <field name="settlement_remaining_amount"
                                   string="剩余额度（风险）"
                                   readonly="1"
                                   class="text-danger"
                                   modifiers="{'invisible': [['settlement_id', '=', False], ['settlement_amount_insufficient', '=', False]]}"/>
                            <field name="settlement_amount_insufficient" invisible="1"/>
                            <div class="o_form_label text-danger"
                                 modifiers="{'invisible': [['settlement_amount_insufficient', '=', False]]}">
                                ⚠ 结算额度不足（剩余额度低于申请金额），系统将阻止提交/完成。
                            </div>
                        </group>
                        <group string="来源匹配">
                            <field name="settlement_match_blocked" invisible="1"/>
                            <field name="settlement_match_warn" invisible="1"/>
                            <field name="settlement_compliance_message" nolabel="1" readonly="1"
                                   class="text-danger"
                                   modifiers="{'invisible': [['settlement_match_blocked', '=', False]]}"/>
                            <field name="settlement_compliance_message" nolabel="1" readonly="1"
                                   class="text-warning"
                                   modifiers="{'invisible': [['settlement_match_warn', '=', False]]}"/>
                            <field name="settlement_compliance_message" nolabel="1" readonly="1"
                                   modifiers="{'invisible': ['|', ['settlement_match_blocked', '=', True], ['settlement_match_warn', '=', True]]}"/>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                        <group string="付款申请明细">
                            <field name="outflow_line_ids" nolabel="1">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="sequence" readonly="1"/>
                                    <field name="source_line_type" readonly="1"/>
                                    <field name="source_document_no" readonly="1"/>
                                    <field name="contract_id"/>
                                    <field name="amount"/>
                                    <field name="paid_before_amount"/>
                                    <field name="remaining_amount"/>
                                    <field name="current_pay_amount"/>
                                </tree>
                            </field>
                        </group>
                        <group string="收款发票明细">
                            <field name="receipt_invoice_line_ids" nolabel="1">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="sequence" readonly="1"/>
                                    <field name="invoice_no"/>
                                    <field name="invoice_party_name"/>
                                    <field name="invoice_amount"/>
                                    <field name="current_receipt_amount"/>
                                    <field name="invoiced_before_amount"/>
                                </tree>
                            </field>
                        </group>
                        <group string="付款记录">
                            <field name="ledger_line_ids" nolabel="1" readonly="1"
                                   context="{'allow_payment_ledger_create': 1}">
                                <tree create="false" edit="false" delete="false">
                                    <field name="paid_at"/>
                                    <field name="amount"/>
                                    <field name="ref"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_payment_request_search" model="ir.ui.view">
            <field name="name">payment.request.search</field>
            <field name="model">payment.request</field>
            <field name="arch" type="xml">
                <search string="付款/收款申请">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="partner_id"/>
                    <field name="contract_id"/>
                    <field name="settlement_id"/>
                    <filter string="付款" name="type_pay" domain="[('type', '=', 'pay')]"/>
                    <filter string="收款" name="type_receive" domain="[('type', '=', 'receive')]"/>
                    <separator/>
                    <filter string="草稿" name="state_draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="已提交" name="state_submit" domain="[('state', '=', 'submit')]"/>
                    <filter string="已批准" name="state_approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="已完成" name="state_done" domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <filter string="按项目" name="group_by_project_id" context="{'group_by': 'project_id'}"/>
                    <filter string="按单位" name="group_by_partner_id" context="{'group_by': 'partner_id'}"/>
                    <filter string="按类型" name="group_by_type" context="{'group_by': 'type'}"/>
                    <filter string="按状态" name="group_by_state" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <record id="action_payment_request" model="ir.actions.act_window">
            <field name="name">付款/收款申请</field>
            <field name="res_model">payment.request</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_payment_request_search"/>
            <field name="context">{'search_default_group_by_project_id': 1}</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('smart_construction_core.group_sc_cap_finance_read'),
                ref('smart_construction_core.group_sc_cap_finance_user'),
                ref('smart_construction_core.group_sc_cap_finance_manager'),
                ref('smart_construction_core.group_sc_cap_business_initiator'),
            ])]"/>
        </record>

        <record id="action_payment_request_pay" model="ir.actions.act_window">
            <field name="name">付款申请</field>
            <field name="res_model">payment.request</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_payment_request_search"/>
            <field name="domain">[('type', '=', 'pay')]</field>
            <field name="context">{'default_type': 'pay', 'search_default_type_pay': 1, 'search_default_group_by_project_id': 1}</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('smart_construction_core.group_sc_cap_finance_read'),
                ref('smart_construction_core.group_sc_cap_finance_user'),
                ref('smart_construction_core.group_sc_cap_finance_manager'),
                ref('smart_construction_core.group_sc_cap_business_initiator'),
            ])]"/>
        </record>

        <record id="action_payment_request_receive" model="ir.actions.act_window">
            <field name="name">收款申请</field>
            <field name="res_model">payment.request</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_payment_request_search"/>
            <field name="domain">[('type', '=', 'receive')]</field>
            <field name="context">{'default_type': 'receive', 'search_default_type_receive': 1, 'search_default_group_by_project_id': 1}</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('smart_construction_core.group_sc_cap_finance_read'),
                ref('smart_construction_core.group_sc_cap_finance_user'),
                ref('smart_construction_core.group_sc_cap_finance_manager'),
                ref('smart_construction_core.group_sc_cap_business_initiator'),
            ])]"/>
        </record>

        <record id="action_payment_request_my" model="ir.actions.act_window">
            <field name="name">我的付款申请</field>
            <field name="res_model">payment.request</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('create_uid', '=', uid)]</field>
            <field name="search_view_id" ref="view_payment_request_search"/>
            <field name="context">{'search_default_group_by_project_id': 1}</field>
            <field name="groups_id" eval="[(6, 0, [
                ref('smart_construction_core.group_sc_cap_finance_read'),
                ref('smart_construction_core.group_sc_cap_finance_user'),
                ref('smart_construction_core.group_sc_cap_finance_manager'),
                ref('smart_construction_core.group_sc_cap_business_initiator'),
            ])]"/>
        </record>

        <menuitem id="menu_payment_request"
                  name="付款申请"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_payment_request_pay"
                  sequence="25"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>

        <menuitem id="menu_payment_request_receive"
                  name="收款申请"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_payment_request_receive"
                  sequence="26"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>

    </data>
</odoo>
