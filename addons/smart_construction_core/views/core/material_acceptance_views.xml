    <record id="action_sc_material_settlement" model="ir.actions.act_window">
        <field name="name">材料结算</field>
        <field name="res_model">sc.material.settlement</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="view_sc_material_settlement_line_search" model="ir.ui.view">
        <field name="name">sc.material.settlement.line.search</field>
        <field name="model">sc.material.settlement.line</field>
        <field name="arch" type="xml">
            <search string="材料结算明细表">
                <field name="settlement_id"/>
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="material_catalog_id"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按材料" name="group_product" context="{'group_by': 'product_id'}"/>
                <filter string="按结算单" name="group_settlement" context="{'group_by': 'settlement_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_settlement_line_tree" model="ir.ui.view">
        <field name="name">sc.material.settlement.line.tree</field>
        <field name="model">sc.material.settlement.line</field>
        <field name="arch" type="xml">
            <tree string="材料结算明细表">
                <field name="settlement_id"/>
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="material_catalog_id"/>
                <field name="material_spec"/>
                <field name="product_uom_id"/>
                <field name="qty" sum="结算数量合计"/>
                <field name="unit_price"/>
                <field name="tax_rate"/>
                <field name="amount_untaxed" sum="未税金额合计"/>
                <field name="tax_amount" sum="税额合计"/>
                <field name="amount_total" sum="含税金额合计"/>
            </tree>
        </field>
    </record>

    <record id="action_sc_material_settlement_line" model="ir.actions.act_window">
        <field name="name">材料结算明细表</field>
        <field name="res_model">sc.material.settlement.line</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="search_view_id" ref="view_sc_material_settlement_line_search"/>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="view_sc_material_purchase_request_tree" model="ir.ui.view">
        <field name="name">sc.material.purchase.request.tree</field>
        <field name="model">sc.material.purchase.request</field>
        <field name="arch" type="xml">
            <tree string="采购申请" default_order="request_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="request_date"/>
                <field name="required_date"/>
                <field name="requester_id"/>
                <field name="department_id"/>
                <field name="purpose"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_purchase_request_form" model="ir.ui.view">
        <field name="name">sc.material.purchase.request.form</field>
        <field name="model">sc.material.purchase.request</field>
        <field name="arch" type="xml">
            <form string="采购申请">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="确认申请" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('approved', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="request_date"/>
                            <field name="required_date"/>
                        </group>
                        <group>
                            <field name="requester_id"/>
                            <field name="department_id"/>
                            <field name="purpose"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="申请明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="material_catalog_id"/>
                                    <field name="material_spec"/>
                                    <field name="product_uom_id"/>
                                    <field name="qty"/>
                                    <field name="estimated_unit_price"/>
                                    <field name="estimated_amount"/>
                                    <field name="currency_id"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="申请说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_purchase_request_search" model="ir.ui.view">
        <field name="name">sc.material.purchase.request.search</field>
        <field name="model">sc.material.purchase.request</field>
        <field name="arch" type="xml">
            <search string="采购申请">
                <field name="name"/>
                <field name="project_id"/>
                <field name="requester_id"/>
                <field name="department_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="待确认" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已确认" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按申请人" name="group_requester" context="{'group_by': 'requester_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_acceptance_tree" model="ir.ui.view">
        <field name="name">sc.material.acceptance.tree</field>
        <field name="model">sc.material.acceptance</field>
        <field name="arch" type="xml">
            <tree string="材料进场验收" default_order="acceptance_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="acceptance_date"/>
                <field name="supplier_id"/>
                <field name="purchase_request_id"/>
                <field name="acceptance_flow"/>
                <field name="source_channel"/>
                <field name="inspector_id"/>
                <field name="sampling_required"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_acceptance_form" model="ir.ui.view">
        <field name="name">sc.material.acceptance.form</field>
        <field name="model">sc.material.acceptance</field>
        <field name="arch" type="xml">
            <form string="材料进场验收">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_accept" string="验收通过" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reject" string="验收不通过" type="object" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state not in ('submitted', 'rejected')"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('accepted', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,accepted,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="acceptance_date"/>
                            <field name="supplier_id"/>
                            <field name="purchase_request_id"/>
                            <field name="acceptance_flow"/>
                            <field name="source_channel"/>
                        </group>
                        <group>
                            <field name="purchase_order_id"/>
                            <field name="inspector_id"/>
                            <field name="supervisor_inspector_id"/>
                            <field name="owner_inspector_id"/>
                            <field name="sampling_required"/>
                            <field name="sampling_report_ref"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="验收明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="material_catalog_id"/>
                                    <field name="material_spec"/>
                                    <field name="product_uom_id"/>
                                    <field name="planned_qty"/>
                                    <field name="received_qty"/>
                                    <field name="accepted_qty"/>
                                    <field name="rejected_qty"/>
                                    <field name="sampled_qty"/>
                                    <field name="returned_qty"/>
                                    <field name="result"/>
                                    <field name="quality_status"/>
                                </tree>
                            </field>
                        </page>
                        <page string="验收说明">
                            <group>
                                <field name="note" nolabel="1"/>
                                <field name="rejection_reason" nolabel="1"/>
                            </group>
                        </page>
                        <page string="验收附件">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_acceptance_search" model="ir.ui.view">
        <field name="name">sc.material.acceptance.search</field>
        <field name="model">sc.material.acceptance</field>
        <field name="arch" type="xml">
            <search string="材料进场验收">
                <field name="name"/>
                <field name="project_id"/>
                <field name="supplier_id"/>
                <field name="purchase_request_id"/>
                <field name="acceptance_flow"/>
                <field name="source_channel"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="待验收" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已通过" name="accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="未通过" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <filter string="需要送检" name="sampling_required" domain="[('sampling_required', '=', True)]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按验收流程" name="group_acceptance_flow" context="{'group_by': 'acceptance_flow'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

