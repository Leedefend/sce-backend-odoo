            <search string="询比价">
                <field name="name"/>
                <field name="project_id"/>
                <field name="purchase_request_id"/>
                <field name="selected_supplier_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已发起" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已定价" name="selected" domain="[('state', '=', 'selected')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'selected_supplier_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_material_settlement_tree" model="ir.ui.view">
        <field name="name">sc.material.settlement.tree</field>
        <field name="model">sc.material.settlement</field>
        <field name="arch" type="xml">
            <tree string="材料结算" default_order="settlement_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="settlement_date"/>
                <field name="supplier_id"/>
                <field name="purchase_order_id"/>
                <field name="amount_untaxed"/>
                <field name="tax_amount"/>
                <field name="amount_total"/>
                <field name="currency_id"/>
                <field name="owner_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_material_settlement_form" model="ir.ui.view">
        <field name="name">sc.material.settlement.form</field>
        <field name="model">sc.material.settlement</field>
        <field name="arch" type="xml">
            <form string="材料结算">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="确认结算" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('confirmed', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="supplier_id"/>
                            <field name="purchase_order_id"/>
                        </group>
                        <group>
                            <field name="settlement_date"/>
                            <field name="owner_id"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="amount_untaxed"/>
                        <field name="tax_amount"/>
                        <field name="amount_total"/>
                    </group>
                    <notebook>
                        <page string="结算明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="material_catalog_id"/>
                                    <field name="material_spec"/>
                                    <field name="product_uom_id"/>
                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="tax_rate"/>
                                    <field name="amount_untaxed"/>
                                    <field name="tax_amount"/>
                                    <field name="amount_total"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="结算说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_material_settlement_search" model="ir.ui.view">
        <field name="name">sc.material.settlement.search</field>
        <field name="model">sc.material.settlement</field>
        <field name="arch" type="xml">
            <search string="材料结算">
                <field name="name"/>
                <field name="project_id"/>
                <field name="supplier_id"/>
                <field name="purchase_order_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已提交" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已确认" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按供应商" name="group_supplier" context="{'group_by': 'supplier_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
</odoo>
