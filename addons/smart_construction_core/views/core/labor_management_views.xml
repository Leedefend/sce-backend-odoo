<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_sc_attendance_checkin" model="ir.actions.act_window">
        <field name="name">考勤记录</field>
        <field name="res_model">sc.attendance.checkin</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="view_sc_attendance_checkin_tree" model="ir.ui.view">
        <field name="name">sc.attendance.checkin.tree</field>
        <field name="model">sc.attendance.checkin</field>
        <field name="arch" type="xml">
            <tree string="考勤记录" default_order="attendance_date desc">
                <field name="name"/>
                <field name="project_id"/>
                <field name="attendance_date"/>
                <field name="labor_team"/>
                <field name="work_content"/>
                <field name="attendance_qty"/>
                <field name="work_hours"/>
                <field name="contractor_id"/>
                <field name="recorder_id"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_attendance_checkin_form" model="ir.ui.view">
        <field name="name">sc.attendance.checkin.form</field>
        <field name="model">sc.attendance.checkin</field>
        <field name="arch" type="xml">
            <form string="考勤记录">
                <header>
                    <button name="action_submit" string="提交" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="确认考勤" type="object" class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="退回草稿" type="object" invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('confirmed', 'cancel')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,confirmed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="attendance_date"/>
                            <field name="labor_team"/>
                        </group>
                        <group>
                            <field name="contractor_id"/>
                            <field name="recorder_id"/>
                            <field name="attendance_qty"/>
                            <field name="work_hours"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="作业内容">
                            <field name="work_content" nolabel="1"/>
                        </page>
                        <page string="考勤说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_attendance_checkin_search" model="ir.ui.view">
        <field name="name">sc.attendance.checkin.search</field>
        <field name="model">sc.attendance.checkin</field>
        <field name="arch" type="xml">
            <search string="考勤记录">
                <field name="name"/>
                <field name="project_id"/>
                <field name="attendance_date"/>
                <field name="labor_team"/>
                <field name="contractor_id"/>
                <field name="recorder_id"/>
                <filter string="草稿" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="已提交" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="已确认" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按班组" name="group_labor_team" context="{'group_by': 'labor_team'}"/>
                <filter string="按劳务单位" name="group_contractor" context="{'group_by': 'contractor_id'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
</odoo>
