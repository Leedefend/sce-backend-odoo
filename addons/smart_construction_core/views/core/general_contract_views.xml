<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_general_contract_search" model="ir.ui.view">
            <field name="name">sc.general.contract.search</field>
            <field name="model">sc.general.contract</field>
            <field name="arch" type="xml">
                <search string="一般合同（公司）">
                    <field name="name"/>
                    <field name="document_no"/>
                    <field name="contract_no"/>
                    <field name="contract_name"/>
                    <field name="project_id"/>
                    <field name="partner_name_text"/>
                    <field name="credit_code"/>
                    <field name="pricing_mode"/>
                    <field name="subcontract_mode"/>
                    <filter string="已确认" name="state_confirmed" domain="[('state', 'in', ['confirmed', 'legacy_confirmed'])]"/>
                    <filter string="已签署" name="state_signed" domain="[('state', '=', 'signed')]"/>
                    <filter string="补充合同" name="supplement" domain="[('is_supplement_contract', 'not in', [False, '', '0'])]"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按合同方" name="group_partner_text" context="{'group_by': 'partner_name_text'}"/>
                    <filter string="按类型" name="group_type" context="{'group_by': 'contract_type'}"/>
                    <filter string="按计价模式" name="group_pricing_mode" context="{'group_by': 'pricing_mode'}"/>
                    <filter string="按分包类型" name="group_subcontract_mode" context="{'group_by': 'subcontract_mode'}"/>
                    <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_general_contract_tree" model="ir.ui.view">
            <field name="name">sc.general.contract.tree</field>
            <field name="model">sc.general.contract</field>
            <field name="arch" type="xml">
                <tree string="一般合同（公司）">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="contract_date"/>
                    <field name="document_no"/>
                    <field name="contract_no"/>
                    <field name="contract_name"/>
                    <field name="project_id"/>
                    <field name="partner_name_text"/>
                    <field name="contact_name"/>
                    <field name="contact_phone"/>
                    <field name="contract_type"/>
                    <field name="contract_attribute"/>
                    <field name="pricing_mode"/>
                    <field name="subcontract_mode"/>
                    <field name="amount_total" sum="最终合同价"/>
                    <field name="settlement_amount" sum="结算金额"/>
                    <field name="invoice_amount" sum="开票金额"/>
                    <field name="uninvoiced_amount" sum="未开票金额"/>
                    <field name="received_amount" sum="收款金额"/>
                    <field name="unreceived_amount" sum="未收款金额"/>
                    <field name="paid_amount" sum="付款金额"/>
                    <field name="unpaid_amount" sum="未付款金额"/>
                    <field name="archived"/>
                    <field name="handler_id"/>
                    <field name="engineering_address"/>
                    <field name="change_rate"/>
                    <field name="tax_rate"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_general_contract_form" model="ir.ui.view">
            <field name="name">sc.general.contract.form</field>
            <field name="model">sc.general.contract</field>
            <field name="arch" type="xml">
                <form string="一般合同（公司）">
                    <header>
                        <button name="action_confirm" string="提交审批" type="object" class="btn-primary"
                                invisible="state != 'draft' or validation_status in ['waiting', 'pending']"
                                groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_contract_user,smart_construction_core.group_sc_cap_contract_manager"/>
                        <button name="validate_tier" string="审批通过" type="object" class="btn-primary"
                                invisible="not can_review"/>
                        <button name="reject_tier" string="审批驳回" type="object"
                                invisible="not can_review"/>
                        <button name="action_signed" string="已签署" type="object" class="btn-primary"
                                invisible="state not in ('draft', 'confirmed')"
                                groups="smart_construction_core.group_sc_cap_contract_manager"/>
                        <button name="action_cancel" string="取消" type="object"
                                invisible="state in ('cancel', 'legacy_confirmed')"
                                groups="smart_construction_core.group_sc_cap_contract_manager"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,signed,legacy_confirmed,cancel"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="project_id" readonly="state == 'legacy_confirmed'"/>
                                <field name="document_no" readonly="state == 'legacy_confirmed'"/>
                                <field name="contract_no" readonly="state == 'legacy_confirmed'"/>
                                <field name="contract_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="contract_type" readonly="state == 'legacy_confirmed'"/>
                                <field name="contract_attribute" readonly="state == 'legacy_confirmed'"/>
                                <field name="template_name" readonly="state == 'legacy_confirmed'"/>
                                <field name="union_mode" readonly="state == 'legacy_confirmed'"/>
                                <field name="pricing_mode" readonly="state == 'legacy_confirmed'"/>
                                <field name="subcontract_mode" readonly="state == 'legacy_confirmed'"/>
                            </group>
                            <group>
                                <field name="company_id" readonly="1"/>
                                <field name="reject_reason" readonly="1" invisible="not reject_reason"/>
                                <field name="contract_date" readonly="state == 'legacy_confirmed'"/>
                                <field name="expected_sign_date" readonly="state == 'legacy_confirmed'"/>
                                <field name="completion_date" readonly="state == 'legacy_confirmed'"/>
                                <field name="signing_place" readonly="state == 'legacy_confirmed'"/>
                                <field name="is_supplement_contract" readonly="state == 'legacy_confirmed'"/>
                                <field name="related_contract_no" readonly="state == 'legacy_confirmed'"/>
                            </group>
                        </group>
                        <group string="金额与条款">
                            <field name="amount_total" readonly="state == 'legacy_confirmed'"/>
                            <field name="amount_untaxed" readonly="state == 'legacy_confirmed'"/>
                            <field name="settlement_amount" readonly="state == 'legacy_confirmed'"/>
                            <field name="invoice_amount" readonly="state == 'legacy_confirmed'"/>
                            <field name="uninvoiced_amount" readonly="1"/>
                            <field name="received_amount" readonly="state == 'legacy_confirmed'"/>
                            <field name="unreceived_amount" readonly="1"/>
                            <field name="paid_amount" readonly="state == 'legacy_confirmed'"/>
                            <field name="unpaid_amount" readonly="1"/>
                            <field name="prepayment_amount" readonly="state == 'legacy_confirmed'"/>
                            <field name="install_commissioning_payment" readonly="state == 'legacy_confirmed'"/>
                            <field name="warranty_deposit" readonly="state == 'legacy_confirmed'"/>
                            <field name="tax_rate" readonly="state == 'legacy_confirmed'"/>
                            <field name="change_amount_total" readonly="state == 'legacy_confirmed'"/>
                            <field name="change_rate" readonly="1"/>
                            <field name="currency_id"/>
                            <field name="payment_terms" readonly="state == 'legacy_confirmed'"/>
                            <field name="special_condition" readonly="state == 'legacy_confirmed'"/>
                        </group>
                        <group string="合同方">
                            <field name="partner_id"/>
                            <field name="partner_name_text" readonly="state == 'legacy_confirmed'"/>
                            <field name="credit_code" readonly="state == 'legacy_confirmed'"/>
                            <field name="contact_name" readonly="state == 'legacy_confirmed'"/>
                            <field name="contact_phone" readonly="state == 'legacy_confirmed'"/>
                            <field name="engineering_address" readonly="state == 'legacy_confirmed'"/>
                            <field name="bank_name" readonly="state == 'legacy_confirmed'"/>
                            <field name="bank_account" readonly="state == 'legacy_confirmed'"/>
                        </group>
                        <group string="办理信息">
                            <field name="applicant_name" readonly="state == 'legacy_confirmed'"/>
                            <field name="applicant_department" readonly="state == 'legacy_confirmed'"/>
                            <field name="purchase_engineer" readonly="state == 'legacy_confirmed'"/>
                            <field name="handler_id" readonly="state == 'legacy_confirmed'"/>
                            <field name="entry_user_id" readonly="1"/>
                            <field name="entry_data" readonly="state == 'legacy_confirmed'"/>
                        </group>
                        <group>
                            <field name="note"/>
                            <field name="active"/>
                            <field name="archived"/>
                        </group>
                        <notebook>
                            <page string="合同附件">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sc_general_contract" model="ir.actions.act_window">
            <field name="name">一般合同（公司）</field>
            <field name="res_model">sc.general.contract</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_general_contract_search"/>
            <field name="context">{'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_contract_manager'))]"/>
        </record>

        <menuitem id="menu_sc_general_contract"
                  name="一般合同（公司）"
                  parent="smart_construction_core.menu_sc_contract_center"
                  action="action_sc_general_contract"
                  sequence="15"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_contract_user,smart_construction_core.group_sc_cap_contract_manager"/>
    </data>
</odoo>
