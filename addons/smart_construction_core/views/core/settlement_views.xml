<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- 列表 -->
        <record id="view_sc_settlement_order_tree" model="ir.ui.view">
            <field name="name">sc.settlement.order.tree</field>
            <field name="model">sc.settlement.order</field>
            <field name="arch" type="xml">
                <tree string="结算单">
                    <field name="name"/>
                    <field name="settlement_type"/>
                    <field name="project_id"/>
                    <field name="contract_id"/>
                    <field name="partner_id"/>
                    <field name="amount_total"/>
                    <field name="amount_paid"/>
                    <field name="amount_payable"/>
                    <field name="state"/>
                    <field name="date_settlement"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_settlement_order_search" model="ir.ui.view">
            <field name="name">sc.settlement.order.search</field>
            <field name="model">sc.settlement.order</field>
            <field name="arch" type="xml">
                <search string="结算单">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="contract_id"/>
                    <field name="partner_id"/>
                    <filter name="state_draft" string="草稿" domain="[('state', '=', 'draft')]"/>
                    <filter name="state_submit" string="已提交" domain="[('state', '=', 'submit')]"/>
                    <filter name="state_approve" string="已批准" domain="[('state', '=', 'approve')]"/>
                    <filter name="state_done" string="已完成" domain="[('state', '=', 'done')]"/>
                    <filter name="state_cancel" string="已取消" domain="[('state', '=', 'cancel')]"/>
                    <filter name="type_out" string="支出结算" domain="[('settlement_type', '=', 'out')]"/>
                    <filter name="type_in" string="收入结算" domain="[('settlement_type', '=', 'in')]"/>
                    <filter name="with_contract" string="有关联合同" domain="[('contract_id', '!=', False)]"/>
                    <group expand="0" string="分组">
                        <filter name="group_project" string="按项目" context="{'group_by': 'project_id'}"/>
                        <filter name="group_contract" string="按合同" context="{'group_by': 'contract_id'}"/>
                        <filter name="group_partner" string="按往来单位" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_type" string="按结算类型" context="{'group_by': 'settlement_type'}"/>
                        <filter name="group_state" string="按状态" context="{'group_by': 'state'}"/>
                        <filter name="group_date_settlement" string="按结算日期" context="{'group_by': 'date_settlement:month'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- 表单 -->
        <record id="view_sc_settlement_order_form" model="ir.ui.view">
            <field name="name">sc.settlement.order.form</field>
            <field name="model">sc.settlement.order</field>
            <field name="arch" type="xml">
                <form string="结算单">
                    <header>
                        <button name="action_submit" type="object" string="提交审批" class="btn-primary" invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')"
                                groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_settlement_user"/>
                        <button name="validate_tier" type="object" string="审批通过" class="btn-primary"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" type="object" string="审批驳回"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_approve" type="object" string="批准" invisible="state != 'submit' or validation_status != 'validated'"
                                groups="smart_construction_core.group_sc_cap_settlement_manager"/>
                        <button name="action_done" type="object" string="完成" invisible="state not in ['approve']"
                                groups="smart_construction_core.group_sc_cap_settlement_manager"/>
                        <button name="action_cancel" type="object" string="取消" invisible="state in ['done','cancel']"
                                groups="smart_construction_core.group_sc_cap_settlement_manager"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submit,approve,done,cancel"/>
                    </header>
                    <sheet>
                        <group string="结算额度">
                            <field name="amount_total" readonly="1"/>
                            <field name="adjustment_total" readonly="1"/>
                            <field name="amount_after_adjustment" readonly="1"/>
                            <field name="amount_paid" readonly="1"/>
                            <field name="amount_payable" readonly="1"
                                   modifiers="{'invisible': [['amount_payable','&lt;',0.0]]}"/>
                            <field name="amount_payable" readonly="1" string="可付余额（风险）"
                                   class="text-danger"
                                   modifiers="{'invisible': [['amount_payable','&gt;=',0.0]]}"/>
                        </group>
                        <group string="来源匹配">
                            <field name="compliance_message"
                                   nolabel="1"
                                   readonly="1"
                                   class="text-danger"
                                   modifiers="{'invisible': [['compliance_state', '!=', 'block']]}"/>
                            <field name="compliance_message"
                                   nolabel="1"
                                   readonly="1"
                                   class="text-warning"
                                   modifiers="{'invisible': [['compliance_state', '!=', 'warn']]}"/>
                            <field name="compliance_message"
                                   nolabel="1"
                                   readonly="1"
                                   modifiers="{'invisible': [['compliance_state', '!=', 'ok']]}"/>
                        </group>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="project_id" options="{'no_create': True}" required="1"/>
                                <field name="settlement_type" required="1"/>
                                <field name="contract_id"
                                       domain="[('project_id','=',project_id),('company_id','=',company_id)]"/>
                            </group>
                            <group>
                                <field name="partner_id" options="{'no_create_edit': True}" required="1"/>
                                <field name="date_settlement"/>
                                <field name="currency_id" required="1"/>
                                <field name="company_id" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="amount_total" readonly="1"/>
                            <field name="note"/>
                        </group>
                        <group string="发票信息（占位）">
                            <field name="invoice_ref"/>
                            <field name="invoice_date"/>
                            <field name="invoice_amount"/>
                        </group>
                        <notebook>
                            <page string="明细">
                                <field name="line_ids">
                                    <tree editable="bottom">
                                        <field name="name"/>
                                        <field name="qty"/>
                                        <field name="price_unit"/>
                                        <field name="amount" readonly="1"/>
                                        <field name="currency_id" invisible="1"/>
                                    </tree>
                                    <form>
                                        <group>
                                            <field name="name"/>
                                            <field name="qty"/>
                                            <field name="price_unit"/>
                                            <field name="amount" readonly="1"/>
                                        </group>
                                    </form>
                                </field>
                            </page>
                            <page string="付款申请">
                                <field name="payment_request_ids" readonly="1" context="{'create': False, 'edit': False}">
                                    <tree>
                                        <field name="name"/>
                                        <field name="project_id"/>
                    <field name="partner_id"/>
                                        <field name="amount"/>
                                        <field name="date_request"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="扣款调整">
                                <field name="adjustment_ids"
                                       context="{'default_project_id': project_id, 'default_settlement_id': id, 'default_contract_id': contract_id, 'default_partner_id': partner_id, 'default_currency_id': currency_id}">
                                    <tree editable="bottom">
                                        <field name="date_adjustment"/>
                                        <field name="adjustment_type"/>
                                        <field name="item_name"/>
                                        <field name="account_name"/>
                                        <field name="amount"/>
                                        <field name="signed_amount" readonly="1"/>
                                        <field name="state" readonly="1"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="采购订单">
                                <group>
                                    <field name="purchase_order_ids"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"/>
                                </group>
                                <field name="purchase_order_ids" nolabel="1" readonly="1">
                                    <tree>
                                        <field name="name"/>
                                        <field name="date_order"/>
                                        <field name="partner_id"/>
                                        <field name="amount_total"/>
                                        <field name="state"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_settlement_adjustment_tree" model="ir.ui.view">
            <field name="name">sc.settlement.adjustment.tree</field>
            <field name="model">sc.settlement.adjustment</field>
            <field name="arch" type="xml">
                <tree string="结算调整" decoration-muted="state == 'cancel'">
                    <field name="date_adjustment"/>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="settlement_id"/>
                    <field name="adjustment_type"/>
                    <field name="item_name"/>
                    <field name="account_name"/>
                    <field name="amount"/>
                    <field name="signed_amount"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_settlement_adjustment_form" model="ir.ui.view">
            <field name="name">sc.settlement.adjustment.form</field>
            <field name="model">sc.settlement.adjustment</field>
            <field name="arch" type="xml">
                <form string="结算调整">
                    <header>
                        <button name="action_confirm" type="object" string="提交审批" class="btn-primary"
                                invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')"
                                groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_settlement_user"/>
                        <button name="validate_tier" string="审批通过" type="object" class="btn-primary"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" string="审批驳回" type="object"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_cancel" type="object" string="取消"
                                invisible="state != 'confirmed'"
                                groups="smart_construction_core.group_sc_cap_settlement_manager"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,legacy_confirmed,cancel"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="adjustment_type" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                                <field name="date_adjustment" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                            </group>
                            <group>
                                <field name="amount" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                                <field name="signed_amount" readonly="1"/>
                                <field name="currency_id" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <group string="业务锚点">
                                <field name="project_id" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                                <field name="settlement_id" readonly="state == 'legacy_confirmed'"/>
                                <field name="contract_id"/>
                                <field name="partner_id"/>
                            </group>
                            <group string="调整事项">
                                <field name="item_name" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                                <field name="account_name" readonly="state in ['confirmed', 'legacy_confirmed', 'cancel']"/>
                            </group>
                        </group>
                        <group>
                            <field name="note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_settlement_adjustment_search" model="ir.ui.view">
            <field name="name">sc.settlement.adjustment.search</field>
            <field name="model">sc.settlement.adjustment</field>
            <field name="arch" type="xml">
                <search string="结算调整">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="settlement_id"/>
                    <field name="item_name"/>
                    <field name="account_name"/>
                    <filter name="active_rows" string="有效" domain="[('active', '=', True)]"/>
                    <filter name="confirmed" string="已确认" domain="[('state', 'in', ['confirmed', 'legacy_confirmed'])]"/>
                    <group expand="0" string="分组">
                        <filter name="group_project" string="项目" context="{'group_by': 'project_id'}"/>
                        <filter name="group_settlement" string="结算单" context="{'group_by': 'settlement_id'}"/>
                        <filter name="group_type" string="调整类型" context="{'group_by': 'adjustment_type'}"/>
                        <filter name="group_state" string="状态" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_sc_settlement_adjustment" model="ir.actions.act_window">
            <field name="name">结算调整</field>
            <field name="res_model">sc.settlement.adjustment</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_settlement_adjustment_search"/>
            <field name="context">{'search_default_active_rows': 1, 'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[
                (4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                (4, ref('smart_construction_core.group_sc_cap_settlement_read')),
                (4, ref('smart_construction_core.group_sc_cap_project_read')),
                (4, ref('smart_construction_core.group_sc_cap_cost_read')),
                (4, ref('smart_construction_core.group_sc_cap_finance_read'))
            ]"/>
        </record>

        <!-- 动作 -->
        <record id="action_sc_settlement_order" model="ir.actions.act_window">
            <field name="name">结算单</field>
            <field name="res_model">sc.settlement.order</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_settlement_order_search"/>
            <field name="context">{'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[
                (4, ref('smart_construction_core.group_sc_cap_settlement_read')),
                (4, ref('smart_construction_core.group_sc_cap_project_read')),
                (4, ref('smart_construction_core.group_sc_cap_cost_read')),
                (4, ref('smart_construction_core.group_sc_cap_finance_read'))
            ]"/>
        </record>

        <!-- 菜单 -->
        <menuitem id="menu_sc_settlement_center"
                  name="结算中心"
                  parent="smart_construction_core.menu_sc_finance_center"
                  sequence="30"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_settlement_read,smart_construction_core.group_sc_cap_project_read,smart_construction_core.group_sc_cap_cost_read,smart_construction_core.group_sc_cap_finance_read"/>

        <menuitem id="menu_sc_settlement_order"
                  name="结算单"
                  parent="menu_sc_settlement_center"
                  action="action_sc_settlement_order"
                  sequence="10"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_settlement_read,smart_construction_core.group_sc_cap_project_read,smart_construction_core.group_sc_cap_cost_read,smart_construction_core.group_sc_cap_finance_read"/>

        <menuitem id="menu_sc_settlement_adjustment"
                  name="结算调整"
                  parent="menu_sc_settlement_center"
                  action="action_sc_settlement_adjustment"
                  sequence="20"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_settlement_read,smart_construction_core.group_sc_cap_project_read,smart_construction_core.group_sc_cap_cost_read,smart_construction_core.group_sc_cap_finance_read"/>

    </data>
</odoo>
