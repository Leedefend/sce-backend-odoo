<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_my_list_tree" model="ir.ui.view">
        <field name="name">project.project.tree.sc.my.list</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <tree string="项目列表" default_order="write_date desc">
                <field name="name" string="项目名称"/>
                <field name="manager_id" string="项目经理"/>
                <field name="owner_id" string="业主单位"/>
                <field name="lifecycle_state" string="当前阶段"/>
                <field name="write_date" string="最近更新"/>
            </tree>
        </field>
    </record>
</odoo>
