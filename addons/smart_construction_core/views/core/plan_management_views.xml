<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_sc_plan" model="ir.actions.act_window">
        <field name="name">计划管理</field>
        <field name="res_model">sc.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_project': 1}</field>
    </record>

    <record id="action_sc_plan_report" model="ir.actions.act_window">
        <field name="name">计划汇报</field>
        <field name="res_model">sc.plan.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_sc_plan_tree" model="ir.ui.view">
        <field name="name">sc.plan.tree</field>
        <field name="model">sc.plan</field>
        <field name="arch" type="xml">
            <tree string="计划" default_order="planned_start desc">
                <field name="name"/>
                <field name="plan_type"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <field name="planned_start"/>
                <field name="planned_finish"/>
                <field name="progress_rate"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_plan_form" model="ir.ui.view">
        <field name="name">sc.plan.form</field>
        <field name="model">sc.plan</field>
        <field name="arch" type="xml">
            <form string="计划">
                <header>
                    <button name="action_confirm" string="确认" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_start" string="开始执行" type="object" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_done" string="完成" type="object" class="btn-primary" invisible="state not in ('confirmed', 'in_progress')"/>
                    <button name="action_cancel" string="取消" type="object" invisible="state in ('done', 'cancel')"/>
                    <button name="action_reset_draft" string="重置草稿" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="plan_type"/>
                            <field name="project_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="owner_id"/>
                            <field name="department_id"/>
                            <field name="planned_start"/>
                            <field name="planned_finish"/>
                            <field name="progress_rate" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="计划节点">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="parent_id"/>
                                    <field name="name"/>
                                    <field name="owner_id"/>
                                    <field name="planned_start"/>
                                    <field name="planned_finish"/>
                                    <field name="progress_rate"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="汇报">
                            <field name="report_ids"/>
                        </page>
                        <page string="版本">
                            <field name="version_ids"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                        <page string="说明">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_sc_plan_search" model="ir.ui.view">
        <field name="name">sc.plan.search</field>
        <field name="model">sc.plan</field>
        <field name="arch" type="xml">
            <search string="计划">
                <field name="name"/>
                <field name="project_id"/>
                <field name="owner_id"/>
                <filter string="执行中" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按类型" name="group_type" context="{'group_by': 'plan_type'}"/>
                <filter string="按状态" name="group_state" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>
</odoo>
