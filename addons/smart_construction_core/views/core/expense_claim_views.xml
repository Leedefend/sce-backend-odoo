<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_expense_claim_tree" model="ir.ui.view">
            <field name="name">sc.expense.claim.tree</field>
            <field name="model">sc.expense.claim</field>
            <field name="arch" type="xml">
                <tree string="费用、保证金与还款办理" decoration-muted="state == 'cancel'">
                    <field name="date_claim"/>
                    <field name="name"/>
                    <field name="claim_flow_label"/>
                    <field name="direction"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="applicant_name"/>
                    <field name="guarantee_project_name"/>
                    <field name="guarantee_type"/>
                    <field name="payment_method"/>
                    <field name="payee"/>
                    <field name="receipt_account_name"/>
                    <field name="payee_account"/>
                    <field name="payee_bank"/>
                    <field name="payment_account_name"/>
                    <field name="payer_account"/>
                    <field name="payer_bank"/>
                    <field name="expense_type"/>
                    <field name="summary"/>
                    <field name="amount" string="办理金额" sum="申请金额合计"/>
                    <field name="approved_amount" sum="批准金额合计"/>
                    <field name="paid_amount" sum="已付款金额合计"/>
                    <field name="unpaid_amount" sum="未付款金额合计"/>
                    <field name="payment_state"/>
                    <field name="claim_type" optional="hide"/>
                    <field name="legacy_document_no"/>
                    <field name="legacy_document_state"/>
                    <field name="creator_name" optional="show"/>
                    <field name="created_time" optional="show"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_expense_claim_form" model="ir.ui.view">
            <field name="name">sc.expense.claim.form</field>
            <field name="model">sc.expense.claim</field>
            <field name="arch" type="xml">
                <form string="费用、保证金与还款办理">
                    <header>
                        <button name="action_submit" type="object" string="提交审批" class="btn-primary"
                                invisible="state != 'draft' or validation_status in ('waiting', 'pending', 'validated')"
                                groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_user"/>
                        <button name="validate_tier" type="object" string="审批通过" class="btn-primary"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="reject_tier" type="object" string="审批驳回"
                                invisible="not can_review or validation_status not in ('waiting', 'pending')"/>
                        <button name="action_approve" type="object" string="批准"
                                invisible="state != 'submit' or validation_status != 'validated'"
                                groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <button name="action_done" type="object" string="完成"
                                invisible="state != 'approved'"
                                groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <button name="action_cancel" type="object" string="取消"
                                invisible="state in ['done', 'legacy_confirmed', 'cancel']"
                                groups="smart_construction_core.group_sc_cap_finance_manager"/>
                        <field name="validation_status" invisible="1"/>
                        <field name="can_review" invisible="1"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submit,approved,done,legacy_confirmed,cancel"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="业务方向">
                                <field name="name" readonly="1"/>
                                <field name="claim_flow_label" readonly="1"/>
                                <field name="claim_type" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="direction" readonly="1"/>
                                <field name="date_claim" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="fill_date" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            </group>
                            <group string="金额与状态">
                                <field name="amount" string="办理金额" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="approved_amount" readonly="state in ['done', 'legacy_confirmed', 'cancel']"/>
                                <field name="paid_amount" readonly="state in ['done', 'legacy_confirmed', 'cancel']"/>
                                <field name="unpaid_amount" readonly="1"/>
                                <field name="payment_state" readonly="state in ['done', 'legacy_confirmed', 'cancel']"/>
                                <field name="currency_id" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']" invisible="1"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <group string="项目与往来单位">
                                <field name="project_id" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="operation_strategy" readonly="1"/>
                                <field name="partner_id"/>
                                <field name="payment_request_id"/>
                                <field name="company_name_text"/>
                                <field name="guarantee_project_name"/>
                                <field name="guarantee_type"/>
                            </group>
                            <group string="申请人与收款方">
                                <field name="applicant_name" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="department_name" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="payee" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="receipt_account_name" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="payee_account" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="payee_bank" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            </group>
                        </group>
                        <group string="付款账户">
                            <group>
                                <field name="payment_account_name" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="payer_account" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                                <field name="payer_bank" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            </group>
                        </group>
                        <group string="保证金办理">
                            <field name="payment_method" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            <field name="clearing_method" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            <field name="is_returned" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            <field name="return_reason" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                        </group>
                        <group string="事项说明">
                            <field name="expense_type" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            <field name="summary" readonly="state in ['approved', 'done', 'legacy_confirmed', 'cancel']"/>
                            <field name="legacy_visible_title" readonly="1" invisible="not legacy_visible_title"/>
                            <field name="legacy_visible_adjustment_item" readonly="1" invisible="not legacy_visible_adjustment_item"/>
                        </group>
                        <group>
                            <field name="note"/>
                            <field name="legacy_visible_push_result" readonly="1" invisible="not legacy_visible_push_result"/>
                            <field name="legacy_document_no" readonly="1" invisible="not legacy_document_no"/>
                            <field name="legacy_document_state" readonly="1" invisible="not legacy_document_state"/>
                            <field name="creator_name" readonly="1"/>
                            <field name="creator_legacy_user_id" readonly="1"/>
                            <field name="created_time" readonly="1"/>
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_sc_expense_claim_search" model="ir.ui.view">
            <field name="name">sc.expense.claim.search</field>
            <field name="model">sc.expense.claim</field>
            <field name="arch" type="xml">
                <search string="费用、保证金与还款办理">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="operation_strategy"/>
                    <field name="partner_id"/>
                    <field name="applicant_name"/>
                    <field name="payee"/>
                    <field name="expense_type"/>
                    <filter name="active_rows" string="有效" domain="[('active', '=', True)]"/>
                    <filter name="outflow" string="流出" domain="[('direction', '=', 'outflow')]"/>
                    <filter name="inflow" string="流入" domain="[('direction', '=', 'inflow')]"/>
                    <filter name="operation_direct" string="公司直营" domain="[('operation_strategy', '=', 'direct')]"/>
                    <filter name="operation_joint" string="联营项目" domain="[('operation_strategy', '=', 'joint')]"/>
                    <filter name="confirmed" string="已确认/完成" domain="[('state', 'in', ['approved', 'done', 'legacy_confirmed'])]"/>
                    <group expand="0" string="分组">
                        <filter name="group_project" string="项目" context="{'group_by': 'project_id'}"/>
                        <filter name="group_operation_strategy" string="经营策略" context="{'group_by': 'operation_strategy'}"/>
                        <filter name="group_partner" string="往来单位" context="{'group_by': 'partner_id'}"/>
                        <filter name="group_type" string="业务类型" context="{'group_by': 'claim_type'}"/>
                        <filter name="group_direction" string="收支方向" context="{'group_by': 'direction'}"/>
                        <filter name="group_expense_type" string="费用类型" context="{'group_by': 'expense_type'}"/>
                        <filter name="group_payment_method" string="支付方式" context="{'group_by': 'payment_method'}"/>
                        <filter name="group_state" string="状态" context="{'group_by': 'state'}"/>
                        <filter name="group_month" string="月份" context="{'group_by': 'date_claim:month'}"/>
                        <filter name="group_date_claim" string="单据日期" context="{'group_by': 'date_claim'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_sc_expense_claim" model="ir.actions.act_window">
            <field name="name">费用/保证金</field>
            <field name="res_model">sc.expense.claim</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_expense_claim_search"/>
            <field name="context">{'search_default_active_rows': 1, 'search_default_group_project': 1}</field>
            <field name="groups_id" eval="[
                (4, ref('smart_construction_core.group_sc_cap_business_initiator')),
                (4, ref('smart_construction_core.group_sc_cap_finance_read')),
                (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                (4, ref('smart_construction_core.group_sc_cap_finance_manager'))
            ]"/>
        </record>

        <menuitem id="menu_sc_expense_claim"
                  name="费用/保证金"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_expense_claim"
                  sequence="28"
                  groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
    </data>
</odoo>
