    <record id="view_construction_contract_expense_search" model="ir.ui.view">
        <field name="name">construction.contract.expense.search</field>
        <field name="model">construction.contract.expense</field>
        <field name="arch" type="xml">
            <search string="支出合同">
                <field name="name"/>
                <field name="subject"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="partner_id"/>
                <field name="expense_contract_category_id"/>
                <filter name="category_material" string="材料" domain="[('expense_contract_category_id.code', '=', 'material')]"/>
                <filter name="category_labor" string="劳务" domain="[('expense_contract_category_id.code', '=', 'labor')]"/>
                <filter name="category_machine" string="机械" domain="[('expense_contract_category_id.code', '=', 'machine')]"/>
                <filter name="category_rental" string="租赁" domain="[('expense_contract_category_id.code', '=', 'rental')]"/>
                <filter name="category_subcontract" string="专业分包" domain="[('expense_contract_category_id.code', '=', 'subcontract')]"/>
                <filter name="category_other" string="其他" domain="[('expense_contract_category_id.code', '=', 'other')]"/>
                <filter name="state_confirmed" string="已确认" domain="[('state', '=', 'confirmed')]"/>
                <filter name="state_running" string="执行中" domain="[('state', '=', 'running')]"/>
                <filter name="operation_direct" string="公司直营" domain="[('operation_strategy', '=', 'direct')]"/>
                <filter name="operation_joint" string="联营项目" domain="[('operation_strategy', '=', 'joint')]"/>
