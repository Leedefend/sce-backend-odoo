    <!-- Search view -->
    <record id="view_construction_contract_search" model="ir.ui.view">
        <field name="name">construction.contract.search</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <search string="项目合同">
                <field name="name"/>
                <field name="subject"/>
                <field name="project_id"/>
                <field name="operation_strategy"/>
                <field name="partner_id"/>
                <field name="category_id"/>
                <field name="contract_type_id"/>
                <filter name="state_draft" string="草稿" domain="[('state', '=', 'draft')]"/>
                <filter name="state_confirmed" string="已确认" domain="[('state', '=', 'confirmed')]"/>
                <filter name="state_running" string="执行中" domain="[('state', '=', 'running')]"/>
                <filter name="state_closed" string="已完成" domain="[('state', '=', 'closed')]"/>
                <filter name="state_cancel" string="已取消" domain="[('state', '=', 'cancel')]"/>
                <filter name="income_contract" string="收入合同" domain="['&amp;', ('type', '=', 'out'), '|', ('legacy_contract_id', '=', False), ('legacy_income_surface_visible', '=', True)]"/>
                <filter name="expense_contract" string="支出合同" domain="[('type', '=', 'in')]"/>
                <filter name="operation_direct" string="公司直营" domain="[('operation_strategy', '=', 'direct')]"/>
                <filter name="operation_joint" string="联营项目" domain="[('operation_strategy', '=', 'joint')]"/>
