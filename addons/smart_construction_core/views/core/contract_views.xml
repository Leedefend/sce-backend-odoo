<odoo>
    <!-- Tree view -->
    <record id="view_construction_contract_tree" model="ir.ui.view">
        <field name="name">construction.contract.tree</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <tree>
                <field name="document_status"/>
                <field name="legacy_document_no"/>
                <field name="date_contract" string="合同订立日期"/>
                <field name="business_category_id" optional="hide"/>
                <field name="archived" string="原件是否归档"/>
                <field name="partner_id" string="发包人"/>
                <field name="project_id" string="项目名称"/>
                <field name="engineering_category_text"/>
                <field name="subject" string="合同标题"/>
                <field name="legacy_contract_no"/>
                <field name="visible_contract_amount" string="合同金额" sum="合同金额合计"/>
                <field name="settlement_amount" sum="结算金额合计"/>
                <field name="visible_invoice_amount" sum="累计开票合计"/>
                <field name="visible_received_amount" sum="累计收款合计"/>
                <field name="visible_unreceived_amount" sum="未收款合计"/>
                <field name="visible_unreceived_rate"/>
                <field name="affiliated_person"/>
                <field name="engineering_address"/>
                <field name="engineering_content"/>
                <field name="contract_duration_text"/>
                <field name="contract_payment_method_text"/>
                <field name="entry_user_text"/>
                <field name="entry_time"/>
                <field name="approval_info"/>
                <field name="attachment_text"/>
                <field name="name" string="平台单据编号"/>
                <field name="legacy_external_contract_no"/>
                <field name="state" string="平台状态"/>
                <field name="operation_strategy"/>
                <field name="type"/>
                <field name="category_id"/>
                <field name="amount_tax" sum="税额合计"/>
                <field name="amount_final" sum="最终合同价合计"/>
                <field name="amount_untaxed" optional="show" sum="平台合同金额合计"/>
                <field name="legacy_contract_amount" optional="show" sum="原系统合同金额合计"/>
                <field name="legacy_contract_amount_delta" optional="show" sum="口径差额合计"/>
                <field name="uninvoiced_amount" sum="未开票金额合计"/>
                <field name="paid_amount" sum="付款金额合计"/>
                <field name="unpaid_amount" sum="未付款金额合计"/>
                <field name="handler_id"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_contract_income_tree" model="ir.ui.view">
        <field name="name">construction.contract.income.tree</field>
        <field name="model">construction.contract.income</field>
        <field name="arch" type="xml">
            <tree string="收入合同">
                <field name="document_status" string="单据状态"/>
                <field name="legacy_document_no" string="单据编号"/>
                <field name="date_contract" string="合同订立日期"/>
                <field name="business_category_id" string="业务分类" optional="hide"/>
                <field name="archived" string="原件是否归档"/>
                <field name="partner_id" string="发包人"/>
                <field name="project_id" string="项目名称"/>
                <field name="subject" string="合同标题"/>
                <field name="engineering_category_text" string="工程类别"/>
                <field name="legacy_contract_no" string="合同编号"/>
                <field name="visible_contract_amount" string="合同金额" sum="合同金额合计"/>
                <field name="settlement_amount" string="结算金额" sum="结算金额合计"/>
                <field name="invoice_amount" string="累计开票" sum="累计开票合计"/>
                <field name="received_amount" string="累计收款" sum="累计收款合计"/>
                <field name="unreceived_amount" string="未收款" sum="未收款合计"/>
                <field name="visible_unreceived_rate" string="未收款比例"/>
                <field name="affiliated_person" string="挂靠人"/>
                <field name="engineering_address" string="工程地址"/>
                <field name="engineering_content" string="工程内容"/>
                <field name="entry_user_text" string="录入人"/>
                <field name="entry_time" string="录入时间"/>
                <field name="attachment_text" string="附件"/>
                <field name="operation_strategy" string="经营方式" optional="hide"/>
                <field name="contract_duration_text" string="合同工期天数" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_construction_contract_expense_tree" model="ir.ui.view">
        <field name="name">construction.contract.expense.tree</field>
        <field name="model">construction.contract.expense</field>
        <field name="arch" type="xml">
            <tree string="支出合同">
                <field name="document_status"/>
                <field name="legacy_document_no"/>
                <field name="date_contract"/>
                <field name="business_category_id" optional="hide"/>
                <field name="partner_id" string="供应商/分包方"/>
                <field name="project_id"/>
                <field name="subject"/>
                <field name="legacy_visible_engineering_content" string="合同内容"/>
                <field name="expense_contract_category_id"/>
                <field name="legacy_contract_no"/>
                <field name="legacy_visible_attachment" string="附件"/>
                <field name="visible_contract_amount" sum="支出合同金额合计"/>
                <field name="settlement_amount" sum="结算金额合计"/>
                <field name="paid_amount" sum="付款金额合计"/>
                <field name="unpaid_amount" sum="未付款金额合计"/>
                <field name="operation_strategy"/>
                <field name="state"/>
                <field name="legacy_visible_creator_name" string="录入人"/>
                <field name="legacy_visible_created_time" string="录入时间"/>
                <field name="note" string="备注"/>
                <field name="handler_id"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_construction_contract_form" model="ir.ui.view">
        <field name="name">construction.contract.form</field>
        <field name="model">construction.contract</field>
        <field name="arch" type="xml">
            <form string="项目合同">
                <header>
                    <button name="action_generate_lines_from_budget"
                            type="object"
                            string="从中标清单生成"
                            class="oe_highlight"
                            modifiers='{"invisible":[["state","!=","draft"]]}'/>
                    <button name="action_confirm"
                            type="object"
                            class="oe_highlight"
                            string="提交审批"
                            modifiers='{"invisible":["|",["state","!=","draft"],["validation_status","in",["waiting","pending"]]]}'
                            groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_contract_user,smart_construction_core.group_sc_cap_contract_manager"/>
                    <button name="validate_tier"
                            type="object"
                            class="oe_highlight"
                            string="审批通过"
                            modifiers='{"invisible":[["can_review","=",false]]}'/>
                    <button name="reject_tier"
                            type="object"
                            string="审批驳回"
                            modifiers='{"invisible":[["can_review","=",false]]}'/>
                    <button name="action_set_running"
                            type="object"
                            string="开始执行"
                            modifiers='{"invisible":[["state","not in",["draft","confirmed"]]]}'
                            groups="smart_construction_core.group_sc_cap_contract_manager"/>
                    <button name="action_close"
                            type="object"
                            string="完成"
                            modifiers='{"invisible":[["state","not in",["running","confirmed"]]]}'
                            groups="smart_construction_core.group_sc_cap_contract_manager"/>
                    <button name="action_cancel"
                            type="object"
                            string="作废"
                            modifiers='{"invisible":[["state","=","cancel"]]}'
                            groups="smart_construction_core.group_sc_cap_contract_manager"/>
                    <button name="action_reset_draft"
                            type="object"
                            string="重置为草稿"
                            modifiers='{"invisible":[["state","!=","cancel"]]}'/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,running,closed,cancel"/>
                    <field name="validation_status" invisible="1"/>
                    <field name="can_review" invisible="1"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="legacy_contract_no"/>
                            <field name="legacy_external_contract_no"/>
                            <field name="legacy_document_no"/>
                            <field name="document_status"/>
                            <field name="subject"/>
                            <field name="type" required="1"/>
                            <field name="business_category_id" options="{'no_create': True}"/>
                            <field name="project_id" required="1"/>
                            <field name="operation_strategy" readonly="1"/>
                            <field name="partner_id" required="1"/>
                            <field name="category_id"/>
                            <field name="contract_type_id"/>
                            <field name="engineering_address"/>
                            <field name="engineering_category_text"/>
                            <field name="affiliated_person"/>
                            <field name="engineering_content"/>
                            <field name="contract_duration_text"/>
                            <field name="contract_payment_method_text"/>
                            <field name="attachment_text"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="1"/>
                            <field name="reject_reason" readonly="1" modifiers='{"invisible": [["reject_reason","=",false]]}'/>
                            <field name="currency_id" invisible="1"/>
                            <field name="date_contract"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="budget_id"/>
                            <field name="analytic_id"/>
                            <field name="handler_id"/>
                            <field name="entry_user_id"/>
                            <field name="entry_data"/>
                            <field name="entry_user_text"/>
                            <field name="entry_time"/>
                            <field name="archived"/>
                            <field name="legacy_status"/>
                        </group>
                    </group>

                    <group string="金额概览" colspan="2">
                        <field name="tax_id"/>
                        <field name="visible_contract_amount" readonly="1"/>
                        <field name="legacy_contract_amount" readonly="1"/>
                        <field name="legacy_contract_amount_delta" readonly="1"/>
                        <field name="amount_untaxed" readonly="1"/>
                        <field name="amount_tax" readonly="1"/>
                        <field name="amount_total" readonly="1"/>
                        <field name="line_amount_total" readonly="1"/>
                        <field name="amount_change" readonly="1"/>
                        <field name="amount_final" readonly="1"/>
                        <field name="settlement_amount" readonly="1"/>
                        <field name="invoice_amount" readonly="1"/>
                        <field name="uninvoiced_amount" readonly="1"/>
                        <field name="received_amount" readonly="1"/>
                        <field name="unreceived_amount" readonly="1"/>
                        <field name="visible_invoice_amount"/>
                        <field name="visible_received_amount"/>
                        <field name="visible_unreceived_amount"/>
                        <field name="visible_unreceived_rate"/>
                        <field name="contract_unreceived_amount" readonly="1"/>
                        <field name="contract_unreceived_rate" readonly="1"/>
                        <field name="paid_amount" readonly="1"/>
                        <field name="unpaid_amount" readonly="1"/>
                    </group>
                    <group string="审批信息" colspan="2">
                        <field name="approval_info"/>
                        <field name="attachment_text"/>
                    </group>

                    <notebook>
                        <page string="合同明细">
                            <field name="line_ids" context="{'default_contract_id': context.get('active_id')}">
                                <tree editable="bottom"
                                      decoration-danger="delta_amount &gt; 0"
                                      decoration-success="delta_amount &lt; 0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="project_id" invisible="1"/>
                                    <field name="boq_line_id"/>
                                    <field name="boq_code"/>
                                    <field name="boq_name"/>
                            <field name="wbs_id"/>
                            <field name="uom_id"/>
                            <field name="qty_contract"/>
                            <field name="price_contract"/>
                            <field name="amount_contract" readonly="1"/>
                            <field name="amount_contract_leaf" sum="合同合价" optional="hide"/>
                            <field name="boq_amount_leaf" readonly="1" optional="hide"/>
                            <field name="boq_amount_source" readonly="1" optional="hide"/>
                            <field name="delta_amount" sum="差额合计" optional="show"/>
                        </tree>
                    </field>
                </page>
                        <page string="备注">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

