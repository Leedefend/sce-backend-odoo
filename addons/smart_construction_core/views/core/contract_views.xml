                    <filter name="group_project" string="按项目" context="{'group_by': 'project_id'}"/>
                    <filter name="group_expense_contract_category" string="按支出合同分类" context="{'group_by': 'expense_contract_category_id'}"/>
                    <filter name="group_operation_strategy" string="按经营策略" context="{'group_by': 'operation_strategy'}"/>
                    <filter name="group_partner" string="按供应商/分包方" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="按状态" context="{'group_by': 'state'}"/>
                    <filter name="group_date_contract" string="按合同日期" context="{'group_by': 'date_contract:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_construction_contract" model="ir.actions.act_window">
        <field name="name">项目合同</field>
        <field name="res_model">construction.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_construction_contract_search"/>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read'))]"/>
    </record>

    <record id="action_construction_contract_my" model="ir.actions.act_window">
        <field name="name">我的合同</field>
        <field name="res_model">construction.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_construction_contract_search"/>
        <field name="domain">['|', ('project_id.user_id', '=', uid), ('project_id.manager_id', '=', uid)]</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read'))]"/>
    </record>

    <record id="action_construction_contract_income" model="ir.actions.act_window">
        <field name="name">收入合同</field>
        <field name="res_model">construction.contract.income</field>
        <field name="view_mode">tree,form</field>
        <field name="views" eval="[(ref('view_construction_contract_income_tree'), 'tree'), (ref('view_construction_contract_income_form'), 'form')]"/>
        <field name="search_view_id" ref="view_construction_contract_income_search"/>
        <field name="domain">[('business_category_id.code', '=', 'contract.income')]</field>
        <field name="context">{'default_type': 'out', 'default_business_category_code': 'contract.income', 'search_default_visible_income': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read'))]"/>
    </record>

    <record id="action_construction_contract_expense" model="ir.actions.act_window">
        <field name="name">支出合同</field>
        <field name="res_model">construction.contract.expense</field>
        <field name="view_mode">tree,form</field>
        <field name="views" eval="[(ref('view_construction_contract_expense_tree'), 'tree'), (ref('view_construction_contract_expense_form'), 'form')]"/>
        <field name="search_view_id" ref="view_construction_contract_expense_search"/>
        <field name="domain">[('business_category_id.code', '=', 'contract.expense')]</field>
        <field name="context">{'default_type': 'in', 'default_business_category_code': 'contract.expense'}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_contract_read'))]"/>
    </record>
</odoo>
