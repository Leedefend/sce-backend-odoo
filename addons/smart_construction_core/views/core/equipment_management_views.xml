                    </group>
                    <notebook>
                        <page string="申请明细">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="equipment_name"/>
                                    <field name="equipment_code"/>
                                    <field name="requested_qty"/>
                                    <field name="planned_hours"/>
                                    <field name="usage_location"/>
                                    <field name="operator_requirement"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="申请说明">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="来源追溯">
                            <group>
                                <field name="legacy_fact_model"/>
                                <field name="legacy_fact_id"/>
                                <field name="legacy_fact_type"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
