        <field name="res_model">tender.bid</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="smart_construction_core.view_tender_bid_search"/>
        <field name="domain">[('state', 'in', ['prepare', 'estimating', 'submitted'])]</field>
        <field name="context">{'default_state': 'prepare'}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_project_read'))]"/>
    </record>
