<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_fund_daily_search" model="ir.ui.view">
            <field name="name">sc.fund.daily.search</field>
            <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
            <field name="arch" type="xml">
                <search string="资金日报">
                    <field name="snapshot_date"/>
                    <field name="project_id"/>
                    <field name="subject"/>
                    <field name="document_no"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按日期" name="group_snapshot_date" context="{'group_by': 'snapshot_date'}"/>
                    <filter string="有差异" name="has_difference" domain="[('source_bank_system_difference', '!=', 0)]"/>
                </search>
            </field>
        </record>

        <record id="action_sc_fund_daily" model="ir.actions.act_window">
            <field name="name">资金日报</field>
            <field name="res_model">sc.legacy.fund.daily.snapshot.fact</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="smart_construction_core.view_sc_legacy_fund_daily_snapshot_fact_tree"/>
            <field name="search_view_id" ref="view_sc_fund_daily_search"/>
            <field name="context">{'search_default_group_snapshot_date': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>

        <record id="view_sc_fund_daily_summary_search" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.search</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <search string="资金日报汇总">
                    <field name="document_date"/>
                    <field name="project_id"/>
                    <field name="project_name"/>
                    <field name="account_name"/>
                    <field name="bank_account_no"/>
                    <filter string="有收入" name="has_income" domain="[('daily_income', '!=', 0)]"/>
                    <filter string="有支出" name="has_expense" domain="[('daily_expense', '!=', 0)]"/>
                    <filter string="有差异" name="has_difference" domain="[('bank_system_difference', '!=', 0)]"/>
                    <filter string="按日期" name="group_document_date" context="{'group_by': 'document_date'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按账户" name="group_account" context="{'group_by': 'account_name'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_fund_daily_summary_tree" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.tree</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <tree string="资金日报汇总" create="0" edit="0" delete="0" default_order="document_date desc, project_id, account_name">
                    <field name="document_date"/>
                    <field name="project_id"/>
                    <field name="project_name"/>
                    <field name="account_name"/>
                    <field name="bank_account_no"/>
                    <field name="line_count" sum="明细数"/>
                    <field name="daily_income" sum="收入合计"/>
                    <field name="daily_expense" sum="支出合计"/>
                    <field name="net_amount" sum="净额合计"/>
                    <field name="current_account_balance" sum="账面余额合计"/>
                    <field name="current_bank_balance" sum="银行余额合计"/>
                    <field name="bank_system_difference" sum="账实差异合计"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_fund_daily_summary_pivot" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.pivot</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <pivot string="资金日报汇总">
                    <field name="document_date" type="row"/>
                    <field name="project_id" type="row"/>
                    <field name="account_name" type="row"/>
                    <field name="daily_income" type="measure"/>
                    <field name="daily_expense" type="measure"/>
                    <field name="net_amount" type="measure"/>
                    <field name="current_account_balance" type="measure"/>
                    <field name="current_bank_balance" type="measure"/>
                    <field name="bank_system_difference" type="measure"/>
                    <field name="line_count" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="view_sc_fund_daily_summary_graph" model="ir.ui.view">
            <field name="name">sc.fund.daily.summary.graph</field>
            <field name="model">sc.fund.daily.summary</field>
            <field name="arch" type="xml">
                <graph string="资金日报趋势" type="bar" stacked="True">
                    <field name="document_date" type="row"/>
                    <field name="daily_income" type="measure"/>
                    <field name="daily_expense" type="measure"/>
                    <field name="net_amount" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="action_sc_fund_daily_summary" model="ir.actions.act_window">
            <field name="name">资金日报汇总</field>
            <field name="res_model">sc.fund.daily.summary</field>
            <field name="view_mode">tree,pivot,graph</field>
            <field name="search_view_id" ref="view_sc_fund_daily_summary_search"/>
            <field name="context">{'create': False, 'search_default_group_document_date': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>

        <record id="view_sc_legacy_fund_daily_line_search" model="ir.ui.view">
            <field name="name">sc.legacy.fund.daily.line.search</field>
            <field name="model">sc.legacy.fund.daily.line</field>
            <field name="arch" type="xml">
                <search string="资金日报明细">
                    <field name="document_no"/>
                    <field name="document_date"/>
                    <field name="project_id"/>
                    <field name="project_name"/>
                    <field name="account_name"/>
                    <field name="bank_account_no"/>
                    <filter string="有项目" name="with_project" domain="[('project_id', '!=', False)]"/>
                    <filter string="有银行差异" name="has_difference" domain="[('bank_system_difference', '!=', 0)]"/>
                    <filter string="有收入" name="has_income" domain="[('daily_income', '!=', 0)]"/>
                    <filter string="有支出" name="has_expense" domain="[('daily_expense', '!=', 0)]"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按日期" name="group_document_date" context="{'group_by': 'document_date'}"/>
                    <filter string="按账户" name="group_account" context="{'group_by': 'account_name'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_legacy_fund_daily_line_tree" model="ir.ui.view">
            <field name="name">sc.legacy.fund.daily.line.tree</field>
            <field name="model">sc.legacy.fund.daily.line</field>
            <field name="arch" type="xml">
                <tree string="资金日报明细" create="0" edit="0" delete="0">
                    <field name="document_date"/>
                    <field name="document_no"/>
                    <field name="project_id"/>
                    <field name="account_name"/>
                    <field name="bank_account_no"/>
                    <field name="daily_income"/>
                    <field name="daily_expense"/>
                    <field name="current_account_balance"/>
                    <field name="current_bank_balance"/>
                    <field name="bank_system_difference"/>
                    <field name="document_state"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_legacy_fund_daily_line_form" model="ir.ui.view">
            <field name="name">sc.legacy.fund.daily.line.form</field>
            <field name="model">sc.legacy.fund.daily.line</field>
            <field name="arch" type="xml">
                <form string="资金日报明细" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="document_date"/>
                                <field name="document_no"/>
                                <field name="document_state"/>
                                <field name="title"/>
                                <field name="project_id"/>
                                <field name="project_name"/>
                            </group>
                            <group>
                                <field name="account_name"/>
                                <field name="bank_account_no"/>
                                <field name="period_start"/>
                                <field name="period_end"/>
                                <field name="creator_name"/>
                                <field name="created_time"/>
                            </group>
                        </group>
                        <group string="当日发生与余额">
                            <group>
                                <field name="daily_income"/>
                                <field name="daily_expense"/>
                                <field name="account_balance"/>
                                <field name="current_account_balance"/>
                            </group>
                            <group>
                                <field name="current_bank_balance"/>
                                <field name="bank_system_difference"/>
                                <field name="header_account_balance_total"/>
                                <field name="header_bank_balance_total"/>
                                <field name="header_bank_system_difference"/>
                            </group>
                        </group>
                        <group>
                            <field name="note"/>
                            <field name="header_note"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sc_fund_daily_line" model="ir.actions.act_window">
            <field name="name">资金日报明细</field>
            <field name="res_model">sc.legacy.fund.daily.line</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_sc_legacy_fund_daily_line_tree"/>
            <field name="search_view_id" ref="view_sc_legacy_fund_daily_line_search"/>
            <field name="context">{'create': False, 'search_default_group_document_date': 1}</field>
            <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                           (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
        </record>

        <menuitem id="menu_sc_fund_daily"
                  name="资金日报"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_fund_daily"
                  sequence="35"
                  groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>

        <menuitem id="menu_sc_fund_daily_summary"
                  name="资金日报汇总"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_fund_daily_summary"
                  sequence="35"
                  groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>

        <menuitem id="menu_sc_fund_daily_line"
                  name="资金日报明细"
                  parent="smart_construction_core.menu_sc_finance_center"
                  action="action_sc_fund_daily_line"
                  sequence="36"
                  groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
    </data>
</odoo>
