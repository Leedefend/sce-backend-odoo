<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_sc_legacy_fuel_card_fact_search" model="ir.ui.view">
    <field name="name">sc.legacy.fuel.card.fact.search</field>
    <field name="model">sc.legacy.fuel.card.fact</field>
    <field name="arch" type="xml">
      <search string="油卡登记">
        <field name="document_no"/>
        <field name="project_name"/>
        <field name="card_no"/>
        <field name="manager_name"/>
        <filter string="有效" name="active_rows" domain="[('active', '=', True)]"/>
        <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
      </search>
    </field>
  </record>

  <record id="view_sc_legacy_fuel_card_fact_tree" model="ir.ui.view">
    <field name="name">sc.legacy.fuel.card.fact.tree</field>
    <field name="model">sc.legacy.fuel.card.fact</field>
    <field name="arch" type="xml">
      <tree string="油卡登记" create="false" edit="false" delete="false">
        <field name="document_date"/>
        <field name="document_no"/>
        <field name="project_id"/>
        <field name="project_name" string="项目名称" optional="show"/>
        <field name="card_no"/>
        <field name="initial_amount" sum="初始金额合计"/>
        <field name="balance_amount" sum="余额合计"/>
        <field name="manager_name"/>
        <field name="document_state"/>
        <field name="creator_name"/>
        <field name="created_time"/>
      </tree>
    </field>
  </record>

  <record id="view_sc_legacy_fuel_card_fact_form" model="ir.ui.view">
    <field name="name">sc.legacy.fuel.card.fact.form</field>
    <field name="model">sc.legacy.fuel.card.fact</field>
    <field name="arch" type="xml">
      <form string="油卡登记" create="false" edit="false" delete="false">
        <sheet>
          <group>
            <group>
              <field name="document_date" readonly="1"/>
              <field name="document_no" readonly="1"/>
              <field name="document_state" readonly="1"/>
              <field name="project_id" readonly="1"/>
              <field name="project_name" readonly="1"/>
            </group>
            <group>
              <field name="card_no" readonly="1"/>
              <field name="initial_amount" readonly="1"/>
              <field name="balance_amount" readonly="1"/>
              <field name="manager_name" readonly="1"/>
            </group>
          </group>
          <group string="附件与审计">
            <field name="attachment_ref" readonly="1"/>
            <field name="note" readonly="1"/>
            <field name="creator_name" readonly="1"/>
            <field name="created_time" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_sc_legacy_fuel_card_fact" model="ir.actions.act_window">
    <field name="name">油卡登记</field>
    <field name="res_model">sc.legacy.fuel.card.fact</field>
    <field name="view_mode">tree,form</field>
    <field name="view_ids" eval="[(5, 0, 0),
      (0, 0, {'view_mode': 'tree', 'view_id': ref('smart_construction_core.view_sc_legacy_fuel_card_fact_tree')}),
      (0, 0, {'view_mode': 'form', 'view_id': ref('smart_construction_core.view_sc_legacy_fuel_card_fact_form')})
    ]"/>
    <field name="search_view_id" ref="smart_construction_core.view_sc_legacy_fuel_card_fact_search"/>
    <field name="context">{'create': False, 'edit': False, 'delete': False, 'search_default_active_rows': 1}</field>
    <field name="groups_id" eval="[(6, 0, [
      ref('smart_construction_core.group_sc_cap_business_initiator'),
      ref('smart_construction_core.group_sc_cap_finance_read'),
      ref('smart_construction_core.group_sc_cap_finance_user'),
      ref('smart_construction_core.group_sc_cap_finance_manager')
    ])]"/>
  </record>

