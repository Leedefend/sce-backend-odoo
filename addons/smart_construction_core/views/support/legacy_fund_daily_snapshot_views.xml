<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_fund_daily_snapshot_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.tree</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <tree string="历史资金日报快照" create="0" edit="0" delete="0">
                <field name="snapshot_date"/>
                <field name="subject"/>
                <field name="project_id"/>
                <field name="source_account_balance_total"/>
                <field name="source_bank_balance_total"/>
                <field name="source_bank_system_difference"/>
                <field name="document_no"/>
                <field name="legacy_state"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_fund_daily_snapshot_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.form</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <form string="历史资金日报快照" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="snapshot_date"/>
                            <field name="subject"/>
                            <field name="project_id"/>
                            <field name="document_no"/>
                            <field name="legacy_state"/>
                        </group>
                        <group>
                            <field name="source_account_balance_total"/>
                            <field name="source_bank_balance_total"/>
                            <field name="source_bank_system_difference"/>
                            <field name="note"/>
                            <field name="legacy_project_id"/>
                            <field name="legacy_project_name"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="legacy_source_table"/>
                            <field name="legacy_record_id"/>
                            <field name="legacy_pid"/>
                            <field name="source_family"/>
                            <field name="import_batch"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
