<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_fund_daily_snapshot_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.tree</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <tree string="企业资金日报" delete="0">
                <field name="snapshot_date"/>
                <field name="business_entity_id"/>
                <field name="subject"/>
                <field name="account_balance_total" sum="账面余额合计"/>
                <field name="bank_balance_total" sum="银行余额合计"/>
                <field name="bank_system_difference" sum="账实差异合计"/>
                <field name="document_no"/>
                <field name="state_text"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_fund_daily_snapshot_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.search</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <search string="企业资金日报">
                <field name="snapshot_date"/>
                <field name="business_entity_id"/>
                <field name="project_id"/>
                <field name="document_no"/>
                <field name="document_scope"/>
                <field name="source_family"/>
                <filter string="有差异" name="has_difference" domain="[('bank_system_difference', '!=', 0)]"/>
                <filter string="企业业务单据" name="scope_enterprise" domain="[('document_scope', '=', 'enterprise')]"/>
                <filter string="项目来源单据" name="scope_project" domain="[('document_scope', '=', 'project')]"/>
                <group expand="1" string="分组">
                    <filter string="按日期" name="group_snapshot_date" context="{'group_by': 'snapshot_date'}"/>
                    <filter string="按业务主体" name="group_business_entity" context="{'group_by': 'business_entity_id'}"/>
                    <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="按单据口径" name="group_document_scope" context="{'group_by': 'document_scope'}"/>
                    <filter string="按来源分类" name="group_source_family" context="{'group_by': 'source_family'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_fund_daily_snapshot_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.form</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <form string="企业资金日报" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="snapshot_date"/>
                            <field name="business_entity_id"/>
                            <field name="company_id"/>
                            <field name="document_scope"/>
                            <field name="subject"/>
                            <field name="project_id"/>
                            <field name="document_no"/>
                            <field name="state_text"/>
                        </group>
                        <group>
                            <field name="account_balance_total"/>
                            <field name="bank_balance_total"/>
                            <field name="bank_system_difference"/>
                            <field name="note"/>
                        </group>
                    </group>
                    <group string="旧库来源">
                        <group>
                            <field name="legacy_source_table"/>
                            <field name="legacy_record_id"/>
                            <field name="legacy_pid"/>
                        </group>
                        <group>
                            <field name="legacy_business_entity_id"/>
                            <field name="legacy_business_entity_name"/>
                            <field name="legacy_project_name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
