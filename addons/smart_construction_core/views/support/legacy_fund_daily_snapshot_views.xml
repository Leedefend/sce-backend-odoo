<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_fund_daily_snapshot_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.tree</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <tree string="资金日报" create="0" edit="0" delete="0">
                <field name="snapshot_date"/>
                <field name="subject"/>
                <field name="project_id"/>
                <field name="account_balance_total"/>
                <field name="bank_balance_total"/>
                <field name="bank_system_difference"/>
                <field name="document_no"/>
                <field name="state_text"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_fund_daily_snapshot_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.fund.daily.snapshot.fact.form</field>
        <field name="model">sc.legacy.fund.daily.snapshot.fact</field>
        <field name="arch" type="xml">
            <form string="资金日报" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="snapshot_date"/>
                            <field name="subject"/>
                            <field name="project_id"/>
                            <field name="document_no"/>
                            <field name="state_text"/>
                        </group>
                        <group>
                            <field name="account_balance_total"/>
                            <field name="bank_balance_total"/>
                            <field name="bank_system_difference"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
