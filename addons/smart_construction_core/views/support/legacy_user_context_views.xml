<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_user_profile_tree" model="ir.ui.view">
        <field name="name">sc.legacy.user.profile.tree</field>
        <field name="model">sc.legacy.user.profile</field>
        <field name="arch" type="xml">
            <tree string="用户信息" create="0" edit="0" delete="0">
                <field name="source_login" string="用户名"/>
                <field name="display_name" string="姓名"/>
                <field name="phone"/>
                <field name="legacy_created_at"/>
                <field name="department_scope_summary"/>
                <field name="role_summary"/>
                <field name="account_state_label"/>
                <field name="login_count"/>
                <field name="last_login_at"/>
                <field name="department_scope_count" optional="hide"/>
                <field name="department_name" optional="hide"/>
                <field name="work_unit" optional="hide"/>
                <field name="employee_no" optional="hide"/>
                <field name="sex" optional="hide"/>
                <field name="credential_type" optional="hide"/>
                <field name="credential_no" optional="hide"/>
                <field name="birth_date" optional="hide"/>
                <field name="education" optional="hide"/>
                <field name="major" optional="hide"/>
                <field name="graduation_school" optional="hide"/>
                <field name="graduation_date" optional="hide"/>
                <field name="professional_title" optional="hide"/>
                <field name="professional_qualification" optional="hide"/>
                <field name="political_status" optional="hide"/>
                <field name="nation" optional="hide"/>
                <field name="native_place" optional="hide"/>
                <field name="residence_address" optional="hide"/>
                <field name="email" optional="hide"/>
                <field name="company_email" optional="hide"/>
                <field name="emergency_contact" optional="hide"/>
                <field name="emergency_phone" optional="hide"/>
                <field name="emergency_relation" optional="hide"/>
                <field name="onboarding_date"/>
                <field name="personnel_type" optional="hide"/>
                <field name="project_name" optional="hide"/>
                <field name="post_salary" optional="hide"/>
                <field name="construction_site" optional="hide"/>
                <field name="bank_name" optional="hide"/>
                <field name="bank_account" optional="hide"/>
                <field name="person_state" optional="hide"/>
                <field name="locked_flag" optional="hide"/>
                <field name="user_id" optional="hide"/>
                <field name="legacy_user_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_user_profile_search" model="ir.ui.view">
        <field name="name">sc.legacy.user.profile.search</field>
        <field name="model">sc.legacy.user.profile</field>
        <field name="arch" type="xml">
            <search string="用户信息">
                <field name="display_name"/>
                <field name="phone"/>
                <field name="source_login"/>
                <field name="department_scope_summary"/>
                <field name="department_name"/>
                <field name="role_summary"/>
                <field name="employee_no"/>
                <field name="credential_no"/>
                <field name="legacy_user_id"/>
                <field name="user_id"/>
                <filter string="已绑定新用户" name="with_user" domain="[('user_id', '!=', False)]"/>
                <filter string="按项目" name="group_project_name" context="{'group_by': 'project_name'}"/>
                <filter string="按部门" name="group_department" context="{'group_by': 'department_name'}"/>
                <filter string="按用户类型" name="group_user_type" context="{'group_by': 'user_type'}"/>
                <filter string="按人员状态" name="group_person_state" context="{'group_by': 'person_state'}"/>
                <filter string="按创建时间" name="group_create_date" context="{'group_by': 'create_date'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_user_role_tree" model="ir.ui.view">
        <field name="name">sc.legacy.user.role.tree</field>
        <field name="model">sc.legacy.user.role</field>
        <field name="arch" type="xml">
            <tree string="历史用户角色" create="0" edit="0" delete="0">
                <field name="legacy_user_id"/>
                <field name="user_id"/>
                <field name="role_name"/>
                <field name="projected_group_ids" widget="many2many_tags"/>
                <field name="projection_state"/>
                <field name="projection_note"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_user_role_search" model="ir.ui.view">
        <field name="name">sc.legacy.user.role.search</field>
        <field name="model">sc.legacy.user.role</field>
        <field name="arch" type="xml">
            <search string="历史用户角色">
                <field name="legacy_user_id"/>
                <field name="role_name"/>
                <field name="user_id"/>
                <filter string="已投影" name="projected" domain="[('projection_state', '=', 'projected')]"/>
                <filter string="未映射" name="unmapped" domain="[('projection_state', '=', 'unmapped')]"/>
                <filter string="按角色" name="group_role" context="{'group_by': 'role_name'}"/>
                <filter string="按投影状态" name="group_projection_state" context="{'group_by': 'projection_state'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_user_project_scope_tree" model="ir.ui.view">
        <field name="name">sc.legacy.user.project.scope.tree</field>
        <field name="model">sc.legacy.user.project.scope</field>
        <field name="arch" type="xml">
            <tree string="历史用户项目范围" create="0" edit="0" delete="0">
                <field name="legacy_user_id"/>
                <field name="user_id"/>
                <field name="project_legacy_id"/>
                <field name="resolved_project_ref"/>
                <field name="project_id"/>
                <field name="scope_state"/>
                <field name="project_access_applied"/>
                <field name="project_access_note"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_user_project_scope_search" model="ir.ui.view">
        <field name="name">sc.legacy.user.project.scope.search</field>
        <field name="model">sc.legacy.user.project.scope</field>
        <field name="arch" type="xml">
            <search string="历史用户项目范围">
                <field name="legacy_user_id"/>
                <field name="user_id"/>
                <field name="project_legacy_id"/>
                <field name="project_id"/>
                <filter string="当前有效" name="current" domain="[('scope_state', '=', 'current')]"/>
                <filter string="已回连项目" name="with_project" domain="[('project_id', '!=', False)]"/>
                <filter string="已应用访问" name="access_applied" domain="[('project_access_applied', '=', True)]"/>
                <filter string="按用户" name="group_user" context="{'group_by': 'user_id'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按状态" name="group_scope_state" context="{'group_by': 'scope_state'}"/>
            </search>
        </field>
    </record>

    <record id="action_sc_legacy_user_profile" model="ir.actions.act_window">
        <field name="name">用户信息</field>
        <field name="res_model">sc.legacy.user.profile</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_user_profile_search"/>
        <field name="context">{}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>

    <record id="view_sc_company_user_roster_tree" model="ir.ui.view">
        <field name="name">res.users.sc.company.roster.tree</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <tree string="公司人员名册" create="0" edit="0" delete="0" default_order="name asc">
                <field name="name" string="姓名"/>
                <field name="phone" string="手机号"/>
                <field name="email" string="邮箱"/>
                <field name="company_id" string="所属公司"/>
                <field name="sc_user_role_group_names" string="业务角色"/>
                <field name="active" string="启用"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_company_user_roster_form" model="ir.ui.view">
        <field name="name">res.users.sc.company.roster.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="公司人员名册" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="人员信息">
                            <field name="name" string="姓名" readonly="1"/>
                            <field name="phone" string="手机号" readonly="1"/>
                            <field name="email" string="邮箱" readonly="1"/>
                        </group>
                        <group string="组织与角色">
                            <field name="company_id" string="所属公司" readonly="1"/>
                            <field name="sc_user_role_group_names" string="业务角色" readonly="1"/>
                            <field name="active" string="启用" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_company_user_roster_search" model="ir.ui.view">
        <field name="name">res.users.sc.company.roster.search</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <search string="公司人员名册">
                <field name="name" string="姓名"/>
                <field name="phone" string="手机号"/>
                <field name="email" string="邮箱"/>
                <field name="company_id" string="所属公司"/>
                <field name="sc_user_role_group_ids" string="业务角色组"/>
                <filter string="启用" name="active_user" domain="[('active', '=', True)]"/>
                <filter string="停用" name="inactive_user" domain="[('active', '=', False)]"/>
                <filter string="按公司" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="按角色" name="group_role" context="{'group_by': 'sc_user_role_group_ids'}"/>
            </search>
        </field>
    </record>

    <record id="action_sc_company_user_roster_formal" model="ir.actions.act_window">
        <field name="name">公司人员名册</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_sc_company_user_roster_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sc_company_user_roster_form')})]"/>
        <field name="search_view_id" ref="view_sc_company_user_roster_search"/>
        <field name="domain">[('sc_runtime_company_real_user', '=', True)]</field>
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('smart_construction_core.group_sc_cap_business_initiator'),
            ref('smart_construction_core.group_sc_cap_business_config_admin')
        ])]"/>
    </record>

    <record id="action_sc_legacy_user_role" model="ir.actions.act_window">
        <field name="name">历史用户角色</field>
        <field name="res_model">sc.legacy.user.role</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_user_role_search"/>
        <field name="context">{'active_test': False}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>

    <record id="action_sc_legacy_user_project_scope" model="ir.actions.act_window">
        <field name="name">历史项目授权范围</field>
        <field name="res_model">sc.legacy.user.project.scope</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_user_project_scope_search"/>
        <field name="context">{'active_test': False, 'search_default_current': 1}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>

    <menuitem id="menu_sc_legacy_user_context"
              name="用户信息与权限"
              parent="smart_construction_core.menu_sc_data_center"
              sequence="70"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <menuitem id="menu_sc_legacy_user_profile"
              name="用户信息"
              parent="menu_sc_legacy_user_context"
              action="action_sc_legacy_user_profile"
              sequence="10"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <menuitem id="menu_sc_legacy_user_role"
              name="历史角色投影"
              parent="menu_sc_legacy_user_context"
              action="action_sc_legacy_user_role"
              sequence="20"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <menuitem id="menu_sc_legacy_user_project_scope"
              name="项目授权范围"
              parent="menu_sc_legacy_user_context"
              action="action_sc_legacy_user_project_scope"
              sequence="30"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <menuitem id="menu_sc_company_user_roster_formal"
              name="公司人员名册"
              parent="smart_construction_core.menu_sc_hr_admin_center"
              action="action_sc_company_user_roster_formal"
              sequence="15"
              groups="smart_construction_core.group_sc_cap_business_initiator,smart_construction_core.group_sc_cap_business_config_admin"/>

    <record id="menu_sc_legacy_user_context" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
    <record id="menu_sc_legacy_user_profile" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
    <record id="menu_sc_legacy_user_role" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
    <record id="menu_sc_legacy_user_project_scope" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
</odoo>
