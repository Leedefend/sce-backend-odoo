<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_enterprise_business_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.enterprise.business.fact.search</field>
        <field name="model">sc.legacy.enterprise.business.fact</field>
        <field name="arch" type="xml">
            <search string="历史企业级业务事实">
                <field name="document_no"/>
                <field name="document_date"/>
                <field name="fact_family"/>
                <field name="company_id"/>
                <field name="business_entity_id"/>
                <field name="partner_id"/>
                <field name="legacy_partner_name"/>
                <filter string="付款" name="family_payment" domain="[('fact_family', '=', 'payment')]"/>
                <filter string="供应商合同" name="family_supplier_contract" domain="[('fact_family', '=', 'supplier_contract')]"/>
                <filter string="企业级无项目" name="scope_enterprise_no_project" domain="[('document_scope', '=', 'enterprise_no_project')]"/>
                <filter string="按事实族" name="group_fact_family" context="{'group_by': 'fact_family'}"/>
                <filter string="按公司" name="group_company" context="{'group_by': 'company_id'}"/>
                <filter string="按往来单位" name="group_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_enterprise_business_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.enterprise.business.fact.tree</field>
        <field name="model">sc.legacy.enterprise.business.fact</field>
        <field name="arch" type="xml">
            <tree string="历史企业级业务事实" create="0" edit="0" delete="0" default_order="document_date desc, id desc">
                <field name="document_date"/>
                <field name="fact_family"/>
                <field name="document_no"/>
                <field name="company_id"/>
                <field name="partner_id"/>
                <field name="amount_total" sum="历史金额合计"/>
                <field name="operation_strategy"/>
                <field name="residual_reason"/>
                <field name="legacy_record_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_enterprise_business_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.enterprise.business.fact.form</field>
        <field name="model">sc.legacy.enterprise.business.fact</field>
        <field name="arch" type="xml">
            <form string="历史企业级业务事实" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="业务事实">
                            <field name="fact_family"/>
                            <field name="document_scope"/>
                            <field name="document_date"/>
                            <field name="document_no"/>
                            <field name="legacy_document_state"/>
                        </group>
                        <group string="隔离口径">
                            <field name="company_id"/>
                            <field name="business_entity_id"/>
                            <field name="operation_strategy"/>
                            <field name="residual_reason"/>
                        </group>
                    </group>
                    <group string="金额与往来">
                        <group>
                            <field name="amount_total"/>
                            <field name="currency_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="legacy_partner_id"/>
                            <field name="legacy_partner_name"/>
                            <field name="import_batch"/>
                        </group>
                    </group>
                    <group string="旧库来源">
                        <group>
                            <field name="legacy_source_model"/>
                            <field name="legacy_source_table"/>
                            <field name="legacy_record_id"/>
                            <field name="legacy_pid"/>
                        </group>
                        <group>
                            <field name="legacy_business_entity_id"/>
                            <field name="legacy_business_entity_name"/>
                            <field name="legacy_project_name"/>
                        </group>
                    </group>
                    <group>
                        <field name="source_note"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_enterprise_business_fact" model="ir.actions.act_window">
        <field name="name">历史企业级业务事实</field>
        <field name="res_model">sc.legacy.enterprise.business.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_enterprise_business_fact_search"/>
        <field name="context">{'create': False, 'search_default_scope_enterprise_no_project': 1, 'search_default_group_fact_family': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager')),
                                       (4, ref('smart_construction_core.group_sc_cap_contract_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_contract_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_contract_manager'))]"/>
    </record>

    <menuitem id="menu_sc_legacy_enterprise_business_fact"
              name="历史企业级业务事实"
              parent="smart_construction_core.menu_sc_finance_center"
              action="action_sc_legacy_enterprise_business_fact"
              sequence="91"
              groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager,smart_construction_core.group_sc_cap_contract_read,smart_construction_core.group_sc_cap_contract_user,smart_construction_core.group_sc_cap_contract_manager"/>
</odoo>
