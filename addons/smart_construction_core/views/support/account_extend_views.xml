<odoo>
    <record id="view_move_form_sc_cost" model="ir.ui.view">
        <field name="name">account.move.form.sc.cost</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group" position="inside">
                <field name="project_id" groups="account.group_account_invoice,account.group_account_readonly"/>
            </xpath>

            <xpath expr="//field[@name='line_ids']/tree/field[@name='name']" position="after">
                <field name="project_id"/>
                <field name="wbs_id"/>
                <field name="cost_code_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_sc_complete_name_contract" model="ir.ui.view">
        <field name="name">res.partner.form.sc.complete.name.contract</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="complete_name" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_sc_customer_partner_tree" model="ir.ui.view">
        <field name="name">res.partner.sc.customer.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="客户" default_order="name">
                <field name="company_type" string="客户类型"/>
                <field name="name" string="单位名称"/>
                <field name="sc_source_project_name" string="关联项目"/>
                <field name="sc_source_receipt_amount" string="收款金额"/>
                <field name="sc_source_payment_amount" string="付款金额"/>
                <field name="sc_supplier_type_label" string="供应商类型" optional="show"/>
                <field name="vat" string="统一社会信用代码"/>
                <field name="sc_default_tax_rate_text" string="主税率"/>
                <field name="sc_business_role_label" string="业务身份" optional="hide"/>
                <field name="sc_business_fact_basis" string="业务依据" optional="hide"/>
                <field name="phone" string="电话" optional="hide"/>
                <field name="mobile" string="手机" optional="hide"/>
                <field name="email" string="电子邮件" optional="hide"/>
                <field name="sc_region" optional="hide"/>
                <field name="sc_bank_name" string="开户银行"/>
                <field name="sc_bank_account" string="账号"/>
                <field name="sc_default_tax_rate" optional="hide"/>
                <field name="active" string="启用" optional="hide"/>
                <field name="user_id" string="负责人" optional="hide"/>
                <field name="category_id" widget="many2many_tags" string="标签" optional="hide"/>
                <field name="comment" string="备注" optional="hide"/>
                <field name="is_company" string="企业/组织" optional="hide"/>
                <field name="sc_registered_capital" optional="hide"/>
                <field name="sc_account_name" optional="hide"/>
                <field name="sc_source_document_state" string="单据状态" optional="hide"/>
                <field name="sc_source_push_result" string="推送结果" optional="hide"/>
                <field name="sc_source_partner_code" string="单位编号" optional="hide"/>
                <field name="sc_source_cooperation_type" string="合作类型" optional="hide"/>
                <field name="sc_source_created_by" string="录入人" optional="hide"/>
                <field name="sc_source_created_at" string="录入时间" optional="hide"/>
                <field name="sc_source_fact_count" string="关联业务数" optional="hide"/>
                <field name="sc_source_fact_source" string="关联业务范围" optional="hide"/>
                <field name="street" string="地址" optional="hide"/>
                <field name="sc_business_scope" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_customer_partner_form" model="ir.ui.view">
        <field name="name">res.partner.sc.customer.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="客户">
                <sheet>
                    <notebook>
                        <page string="客户身份">
                            <group>
                                <group>
                                    <field name="name" string="客户名称"/>
                                    <field name="company_type" string="客户类型"/>
                                    <field name="user_id" string="负责人"/>
                                    <field name="category_id" widget="many2many_tags" string="标签"/>
                                </group>
                                <group>
                                    <field name="sc_business_role_label" string="业务身份" readonly="1"/>
                                    <field name="sc_business_fact_basis" string="业务依据" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="企业资质">
                            <group>
                                <group>
                                    <field name="vat" string="统一社会信用代码/税号"/>
                                    <field name="company_registry" string="工商注册号"/>
                                    <field name="industry_id" string="行业"/>
                                    <field name="sc_region"/>
                                </group>
                                <group>
                                    <field name="sc_registered_capital"/>
                                    <field name="sc_default_tax_rate"/>
                                    <field name="sc_default_tax_rate_text" string="主税率"/>
                                    <field name="sc_business_scope"/>
                                </group>
                            </group>
                        </page>
                        <page string="联系与地址">
                            <group>
                                <group>
                                    <field name="phone" string="电话"/>
                                    <field name="mobile" string="手机"/>
                                    <field name="email" string="电子邮件"/>
                                    <field name="website" string="网站"/>
                                </group>
                                <group>
                                    <field name="street" string="街道地址"/>
                                    <field name="street2" string="详细地址"/>
                                    <field name="city" string="城市"/>
                                    <field name="state_id" string="省/州"/>
                                    <field name="zip" string="邮编"/>
                                    <field name="country_id" string="国家/地区"/>
                                </group>
                            </group>
                        </page>
                        <page string="账户与开票">
                            <group>
                                <group>
                                    <field name="sc_account_name" string="账户名称"/>
                                    <field name="sc_bank_name" string="开户银行"/>
                                    <field name="sc_bank_account" string="银行账号"/>
                                    <field name="property_payment_term_id" string="客户付款条件"/>
                                </group>
                                <group>
                                    <field name="property_account_position_id" string="财政状况"/>
                                    <field name="property_account_receivable_id" string="应收账款科目"/>
                                </group>
                            </group>
                        </page>
                        <page string="联系人">
                            <field name="child_ids" mode="tree,form" context="{'default_parent_id': id}">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="function"/>
                                    <field name="phone"/>
                                    <field name="mobile"/>
                                    <field name="email"/>
                                </tree>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="function"/>
                                            <field name="phone"/>
                                            <field name="mobile"/>
                                            <field name="email"/>
                                            <field name="street"/>
                                            <field name="comment"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="备注">
                            <field name="comment" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_customer_partner_search" model="ir.ui.view">
        <field name="name">res.partner.sc.customer.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="客户">
                <field name="name" string="名称"/>
                <field name="vat" string="统一社会信用代码"/>
                <field name="sc_region"/>
                <field name="sc_default_tax_rate"/>
                <field name="sc_default_tax_rate_text" string="主税率"/>
                <field name="sc_bank_name"/>
                <field name="sc_bank_account"/>
                <field name="phone"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="sc_source_partner_code" string="单位编号"/>
                <field name="sc_source_document_state" string="单据状态"/>
                <field name="sc_source_push_result" string="推送结果"/>
                <field name="sc_source_project_name" string="关联项目"/>
                <field name="sc_source_cooperation_type" string="合作类型"/>
                <field name="sc_supplier_type_label" string="供应商类型"/>
                <field name="sc_source_created_by" string="录入人"/>
                <field name="sc_business_role_label" string="业务身份"/>
                <field name="sc_business_fact_basis" string="业务依据"/>
                <field name="category_id" string="标签"/>
                <field name="user_id" string="负责人"/>
                <field name="active" string="启用"/>
                <field name="comment" string="备注"/>
                <field name="street" string="地址"/>
                <field name="sc_business_scope" string="经营范围"/>
                <filter string="企业/组织" name="customer_company" domain="[('is_company', '=', True)]"/>
                <filter string="个人" name="customer_person" domain="[('is_company', '=', False)]"/>
                <filter string="客户兼供应商" name="customer_supplier_mixed" domain="[('supplier_rank', '&gt;', 0)]"/>
                <filter string="含银行账户" name="customer_with_bank_account" domain="[('sc_bank_account', '!=', False)]"/>
                <filter string="已归档" name="customer_inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="按业务身份" name="group_business_role" context="{'group_by': 'sc_business_role_label'}"/>
                <filter string="按业务依据" name="group_business_fact_basis" context="{'group_by': 'sc_business_fact_basis'}"/>
                <filter string="按企业组织/个人" name="group_is_company" context="{'group_by': 'is_company'}"/>
                <filter string="按负责人" name="group_user" context="{'group_by': 'user_id'}"/>
                <filter string="按地区" name="group_region" context="{'group_by': 'sc_region'}"/>
                <filter string="按默认税率" name="group_default_tax_rate" context="{'group_by': 'sc_default_tax_rate'}"/>
            </search>
        </field>
    </record>

