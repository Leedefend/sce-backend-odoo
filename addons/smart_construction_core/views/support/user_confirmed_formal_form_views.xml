    <record id="view_project_project_user_confirmed_form_fields" model="ir.ui.view">
        <field name="name">project.project.user.confirmed.form.fields</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="用户确认数据">
                    <field name="sc_partner_display_name" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

