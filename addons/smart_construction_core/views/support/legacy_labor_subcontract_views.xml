<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_labor_subcontract_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.labor.subcontract.fact.search</field>
        <field name="model">sc.legacy.labor.subcontract.fact</field>
        <field name="arch" type="xml">
            <search string="历史劳务/分包事实">
                <field name="document_no"/>
                <field name="project_id"/>
                <field name="project_name"/>
                <field name="partner_name"/>
                <field name="contract_no"/>
                <field name="contract_name"/>
                <field name="work_scope"/>
                <field name="source_table"/>
                <filter string="有效" name="active_only" domain="[('active', '=', True)]"/>
                <filter string="有项目锚点" name="with_project" domain="[('project_id', '!=', False)]"/>
                <filter string="有金额" name="with_amount" domain="[('amount_total', '!=', 0)]"/>
                <filter string="劳务合同" name="labor_contract" domain="[('fact_type', '=', 'labor_contract')]"/>
                <filter string="分包合同" name="subcontract_contract" domain="[('fact_type', '=', 'subcontract_contract')]"/>
                <filter string="劳务结算" name="labor_settlement" domain="[('fact_type', '=', 'labor_settlement')]"/>
                <filter string="分包结算" name="subcontract_settlement" domain="[('fact_type', '=', 'subcontract_settlement')]"/>
                <filter string="按事实类型" name="group_fact_type" context="{'group_by': 'fact_type'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按单位" name="group_partner_name" context="{'group_by': 'partner_name'}"/>
                <filter string="按来源表" name="group_source_table" context="{'group_by': 'source_table'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_labor_subcontract_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.labor.subcontract.fact.tree</field>
        <field name="model">sc.legacy.labor.subcontract.fact</field>
        <field name="arch" type="xml">
            <tree string="历史劳务/分包事实" create="0" edit="0" delete="0">
                <field name="document_date"/>
                <field name="fact_type"/>
                <field name="document_no"/>
                <field name="project_id"/>
                <field name="project_name"/>
                <field name="partner_name"/>
                <field name="contract_no"/>
                <field name="contract_name"/>
                <field name="work_scope"/>
                <field name="amount_total" sum="事实金额合计"/>
                <field name="amount_contract" sum="合同金额合计"/>
                <field name="amount_settlement" sum="结算金额合计"/>
                <field name="source_table"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_labor_subcontract_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.labor.subcontract.fact.form</field>
        <field name="model">sc.legacy.labor.subcontract.fact</field>
        <field name="arch" type="xml">
            <form string="历史劳务/分包事实" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="state" readonly="1"/>
                            <field name="fact_type"/>
                            <field name="source_table"/>
                            <field name="source_dataset"/>
                            <field name="document_no"/>
                            <field name="document_state"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="project_legacy_id"/>
                            <field name="project_name"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="合同与单位">
                        <group>
                            <field name="partner_legacy_id"/>
                            <field name="partner_name"/>
                            <field name="contract_legacy_id"/>
                            <field name="contract_no"/>
                            <field name="contract_name"/>
                        </group>
                        <group>
                            <field name="work_scope"/>
                            <field name="work_part"/>
                            <field name="department_name"/>
                        </group>
                    </group>
                    <group string="日期">
                        <group>
                            <field name="document_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="created_time"/>
                            <field name="creator_name"/>
                            <field name="creator_legacy_user_id"/>
                        </group>
                    </group>
                    <group string="金额">
                        <group>
                            <field name="amount_total"/>
                            <field name="amount_contract"/>
                            <field name="amount_settlement"/>
                        </group>
                        <group>
                            <field name="amount_payable"/>
                            <field name="amount_deduction"/>
                            <field name="tax_rate"/>
                        </group>
                    </group>
                    <group string="账户与来源">
                        <group>
                            <field name="bank_name"/>
                            <field name="bank_account"/>
                            <field name="attachment_ref"/>
                        </group>
                        <group>
                            <field name="legacy_record_id"/>
                            <field name="legacy_pid"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_labor_subcontract_fact" model="ir.actions.act_window">
        <field name="name">历史劳务/分包事实</field>
        <field name="res_model">sc.legacy.labor.subcontract.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_labor_subcontract_fact_search"/>
        <field name="context">{'search_default_active_only': 1, 'search_default_group_fact_type': 1}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>

    <menuitem id="menu_sc_legacy_labor_subcontract_fact_labor"
              name="历史劳务/分包事实"
              parent="smart_construction_core.menu_sc_labor_management_group"
              action="smart_construction_core.action_sc_legacy_labor_subcontract_fact"
              sequence="45"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <menuitem id="menu_sc_legacy_labor_subcontract_fact_subcontract"
              name="历史劳务/分包事实"
              parent="smart_construction_core.menu_sc_subcontract_management_group"
              action="smart_construction_core.action_sc_legacy_labor_subcontract_fact"
              sequence="45"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <record id="menu_sc_legacy_labor_subcontract_fact_labor" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
    <record id="menu_sc_legacy_labor_subcontract_fact_subcontract" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
</odoo>
