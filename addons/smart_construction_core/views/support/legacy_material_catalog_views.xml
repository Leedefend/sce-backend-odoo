<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_material_detail_search" model="ir.ui.view">
        <field name="name">sc.legacy.material.detail.search</field>
        <field name="model">sc.legacy.material.detail</field>
        <field name="arch" type="xml">
            <search string="物料档案">
                <field name="code"/>
                <field name="name"/>
                <field name="spec_model"/>
                <field name="uom_text"/>
                <field name="category_id"/>
                <field name="project_id"/>
                <filter string="有分类" name="with_category" domain="[('category_id', '!=', False)]"/>
                <filter string="项目物料" name="with_project" domain="[('project_id', '!=', False)]"/>
                <filter string="按分类" name="group_category" context="{'group_by': 'category_id'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按单位" name="group_uom" context="{'group_by': 'uom_text'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_material_detail_tree" model="ir.ui.view">
        <field name="name">sc.legacy.material.detail.tree</field>
        <field name="model">sc.legacy.material.detail</field>
        <field name="arch" type="xml">
            <tree string="物料档案" create="0" edit="0" delete="0">
                <field name="code"/>
                <field name="name"/>
                <field name="spec_model"/>
                <field name="uom_text"/>
                <field name="planned_price"/>
                <field name="internal_price"/>
                <field name="category_id"/>
                <field name="project_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_material_detail_form" model="ir.ui.view">
        <field name="name">sc.legacy.material.detail.form</field>
        <field name="model">sc.legacy.material.detail</field>
        <field name="arch" type="xml">
            <form string="物料档案" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="spec_model"/>
                        </group>
                        <group>
                            <field name="category_id"/>
                            <field name="project_id"/>
                            <field name="depth"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="单位与价格">
                        <group>
                            <field name="uom_text"/>
                            <field name="aux_uom_text"/>
                        </group>
                        <group>
                            <field name="planned_price"/>
                            <field name="internal_price"/>
                        </group>
                    </group>
                    <group>
                        <field name="remark"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sc_legacy_material_category_tree" model="ir.ui.view">
        <field name="name">sc.legacy.material.category.tree</field>
        <field name="model">sc.legacy.material.category</field>
        <field name="arch" type="xml">
            <tree string="物料分类" create="0" edit="0" delete="0">
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="project_id"/>
                <field name="depth"/>
                <field name="uom_text"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_material_category_search" model="ir.ui.view">
        <field name="name">sc.legacy.material.category.search</field>
        <field name="model">sc.legacy.material.category</field>
        <field name="arch" type="xml">
            <search string="物料分类">
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="project_id"/>
                <filter string="有父级" name="with_parent" domain="[('parent_id', '!=', False)]"/>
                <filter string="按父级" name="group_parent" context="{'group_by': 'parent_id'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_sc_legacy_material_detail" model="ir.actions.act_window">
        <field name="name">物料档案</field>
        <field name="res_model">sc.legacy.material.detail</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_material_detail_search"/>
        <field name="context">{'create': False}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_material_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_material_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_material_manager'))]"/>
    </record>

    <record id="action_sc_legacy_material_category" model="ir.actions.act_window">
        <field name="name">物料分类</field>
        <field name="res_model">sc.legacy.material.category</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_sc_legacy_material_category_search"/>
        <field name="context">{'create': False}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_material_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_material_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_material_manager'))]"/>
    </record>

    <menuitem id="menu_sc_legacy_material_detail"
              name="物料档案"
              parent="smart_construction_core.menu_sc_material_center"
              action="action_sc_legacy_material_detail"
              sequence="50"
              groups="smart_construction_core.group_sc_cap_material_read,smart_construction_core.group_sc_cap_material_user,smart_construction_core.group_sc_cap_material_manager"/>

    <menuitem id="menu_sc_legacy_material_category"
              name="物料分类"
              parent="smart_construction_core.menu_sc_material_center"
              action="action_sc_legacy_material_category"
              sequence="55"
              groups="smart_construction_core.group_sc_cap_material_read,smart_construction_core.group_sc_cap_material_user,smart_construction_core.group_sc_cap_material_manager"/>
</odoo>
