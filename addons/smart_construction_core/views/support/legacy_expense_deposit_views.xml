<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_sc_legacy_expense_deposit_fact_tree" model="ir.ui.view">
    <field name="name">sc.legacy.expense.deposit.fact.tree</field>
    <field name="model">sc.legacy.expense.deposit.fact</field>
    <field name="arch" type="xml">
      <tree string="历史费用/保证金事实" create="false" edit="false" delete="false">
        <field name="document_date"/>
        <field name="document_no"/>
        <field name="direction"/>
        <field name="project_id"/>
        <field name="partner_id"/>
        <field name="source_amount"/>
        <field name="source_amount_field"/>
        <field name="legacy_state"/>
        <field name="source_family"/>
        <field name="legacy_source_table"/>
        <field name="legacy_record_id"/>
        <field name="import_batch"/>
      </tree>
    </field>
  </record>

  <record id="view_sc_legacy_expense_deposit_fact_search" model="ir.ui.view">
    <field name="name">sc.legacy.expense.deposit.fact.search</field>
    <field name="model">sc.legacy.expense.deposit.fact</field>
    <field name="arch" type="xml">
      <search string="历史费用/保证金事实">
        <field name="document_no"/>
        <field name="document_date"/>
        <field name="project_id"/>
        <field name="partner_id"/>
        <field name="legacy_partner_name"/>
        <field name="source_family"/>
        <filter string="有往来方" name="with_partner" domain="[('partner_id', '!=', False)]"/>
        <filter string="流出" name="direction_out" domain="[('direction', '=', 'outflow')]"/>
        <filter string="流入/退回" name="direction_refund" domain="[('direction', '=', 'inflow_or_refund')]"/>
        <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
        <filter string="按往来方" name="group_partner" context="{'group_by': 'partner_id'}"/>
        <filter string="按类型" name="group_family" context="{'group_by': 'source_family'}"/>
      </search>
    </field>
  </record>

  <record id="view_sc_legacy_expense_deposit_fact_form" model="ir.ui.view">
    <field name="name">sc.legacy.expense.deposit.fact.form</field>
    <field name="model">sc.legacy.expense.deposit.fact</field>
    <field name="arch" type="xml">
      <form string="历史费用/保证金事实" create="false" edit="false" delete="false">
        <sheet>
          <group>
            <group>
              <field name="document_date"/>
              <field name="document_no"/>
              <field name="direction"/>
              <field name="project_id"/>
              <field name="partner_id"/>
              <field name="source_amount"/>
              <field name="source_amount_field"/>
            </group>
            <group>
              <field name="legacy_state"/>
              <field name="source_family"/>
              <field name="legacy_source_table"/>
              <field name="legacy_record_id"/>
              <field name="legacy_pid"/>
              <field name="import_batch"/>
            </group>
          </group>
          <group>
            <field name="legacy_project_id"/>
            <field name="legacy_project_name"/>
            <field name="legacy_partner_id"/>
            <field name="legacy_partner_name"/>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_sc_legacy_expense_deposit_fact" model="ir.actions.act_window">
    <field name="name">历史费用/保证金事实</field>
    <field name="res_model">sc.legacy.expense.deposit.fact</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_sc_legacy_expense_deposit_fact_search"/>
    <field name="context">{'create': False, 'search_default_group_family': 1}</field>
    <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                   (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                   (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
  </record>

  <record id="view_sc_legacy_expense_reimbursement_line_tree" model="ir.ui.view">
    <field name="name">sc.legacy.expense.reimbursement.line.tree</field>
    <field name="model">sc.legacy.expense.reimbursement.line</field>
    <field name="arch" type="xml">
      <tree string="历史费用报销明细" create="false" edit="false" delete="false">
        <field name="document_date"/>
        <field name="document_no"/>
        <field name="document_state"/>
        <field name="project_id"/>
        <field name="applicant_name"/>
        <field name="reimbursement_type"/>
        <field name="finance_type"/>
        <field name="amount"/>
        <field name="approved_amount"/>
        <field name="payee"/>
        <field name="payee_bank"/>
      </tree>
    </field>
  </record>

  <record id="view_sc_legacy_expense_reimbursement_line_search" model="ir.ui.view">
    <field name="name">sc.legacy.expense.reimbursement.line.search</field>
    <field name="model">sc.legacy.expense.reimbursement.line</field>
    <field name="arch" type="xml">
      <search string="历史费用报销明细">
        <field name="document_no"/>
        <field name="document_date"/>
        <field name="project_id"/>
        <field name="project_name"/>
        <field name="applicant_name"/>
        <field name="reimbursement_type"/>
        <field name="finance_type"/>
        <field name="payee"/>
        <filter string="有项目" name="with_project" domain="[('project_id', '!=', False)]"/>
        <filter string="有收款人" name="with_payee" domain="[('payee', '!=', False)]"/>
        <filter string="有批准金额" name="with_approved_amount" domain="[('approved_amount', '!=', 0)]"/>
        <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
        <filter string="按申请人" name="group_applicant" context="{'group_by': 'applicant_name'}"/>
        <filter string="按费用类型" name="group_finance_type" context="{'group_by': 'finance_type'}"/>
      </search>
    </field>
  </record>

  <record id="view_sc_legacy_expense_reimbursement_line_form" model="ir.ui.view">
    <field name="name">sc.legacy.expense.reimbursement.line.form</field>
    <field name="model">sc.legacy.expense.reimbursement.line</field>
    <field name="arch" type="xml">
      <form string="历史费用报销明细" create="false" edit="false" delete="false">
        <sheet>
          <group>
            <group>
              <field name="document_date"/>
              <field name="document_no"/>
              <field name="document_state"/>
              <field name="company_name"/>
              <field name="department_name"/>
              <field name="project_id"/>
              <field name="project_name"/>
            </group>
            <group>
              <field name="applicant_name"/>
              <field name="applicant_contact"/>
              <field name="applicant_position"/>
              <field name="reimbursement_type"/>
              <field name="finance_type"/>
              <field name="payment_method"/>
            </group>
          </group>
          <group string="金额与收款">
            <group>
              <field name="amount"/>
              <field name="quantity"/>
              <field name="unit_price"/>
              <field name="allocated_amount"/>
              <field name="header_total"/>
              <field name="requested_amount"/>
              <field name="approved_amount"/>
            </group>
            <group>
              <field name="writeoff_amount"/>
              <field name="advance_amount"/>
              <field name="payee"/>
              <field name="payee_account"/>
              <field name="payee_bank"/>
            </group>
          </group>
          <group string="业务说明">
            <field name="summary"/>
            <field name="participant"/>
            <field name="participant_count"/>
            <field name="deducted_participant"/>
            <field name="deducted_count"/>
            <field name="invoice_content"/>
          </group>
          <group string="旧系统来源">
            <group>
              <field name="legacy_line_id"/>
              <field name="legacy_header_id"/>
              <field name="legacy_pid"/>
              <field name="legacy_header_pid"/>
              <field name="source_table"/>
            </group>
            <group>
              <field name="company_legacy_id"/>
              <field name="department_legacy_id"/>
              <field name="project_legacy_id"/>
              <field name="line_project_legacy_id"/>
              <field name="attachment_ref"/>
              <field name="line_attachment_ref"/>
            </group>
          </group>
          <group>
            <field name="note"/>
            <field name="header_note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_sc_legacy_expense_reimbursement_line" model="ir.actions.act_window">
    <field name="name">历史费用报销明细</field>
    <field name="res_model">sc.legacy.expense.reimbursement.line</field>
    <field name="view_mode">tree,form</field>
    <field name="view_id" ref="view_sc_legacy_expense_reimbursement_line_tree"/>
    <field name="search_view_id" ref="view_sc_legacy_expense_reimbursement_line_search"/>
    <field name="context">{'create': False, 'search_default_group_finance_type': 1}</field>
    <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                   (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                   (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
  </record>
</odoo>
