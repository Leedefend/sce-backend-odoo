<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_business_evidence_tree" model="ir.ui.view">
        <field name="name">sc.business.evidence.tree</field>
        <field name="model">sc.business.evidence</field>
        <field name="arch" type="xml">
            <tree string="Business Evidence" create="false" edit="false" delete="false">
                <field name="operate_time"/>
                <field name="name"/>
                <field name="evidence_type"/>
                <field name="business_model"/>
                <field name="business_id"/>
                <field name="amount"/>
                <field name="quantity"/>
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="operator_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_business_evidence_form" model="ir.ui.view">
        <field name="name">sc.business.evidence.form</field>
        <field name="model">sc.business.evidence</field>
        <field name="arch" type="xml">
            <form string="Business Evidence" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="evidence_type"/>
                            <field name="operate_time"/>
                            <field name="operator_id"/>
                        </group>
                        <group>
                            <field name="business_model"/>
                            <field name="business_id"/>
                            <field name="source_model"/>
                            <field name="source_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="amount"/>
                            <field name="quantity"/>
                        </group>
                    </group>
                    <group>
                        <field name="relation_chain" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_business_evidence" model="ir.actions.act_window">
        <field name="name">Business Evidence</field>
        <field name="res_model">sc.business.evidence</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- 迁移事实资产：只读原生页面，便于重建后核验历史业务事实 -->
    <record id="view_sc_legacy_workflow_audit_tree" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.tree</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <tree string="审批记录查询" create="false" edit="false" delete="false">
                <field name="approved_at"/>
                <field name="actor_name"/>
                <field name="action_classification" string="处理结果"/>
                <field name="target_lane" string="业务分类"/>
                <field name="legacy_step_name" string="步骤"/>
                <field name="legacy_template_name" string="流程模板"/>
            </tree>
        </field>
    </record>
    <record id="view_sc_legacy_workflow_audit_form" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.form</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <form string="审批记录查询" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="target_lane" string="业务分类"/>
                            <field name="target_model" invisible="1"/>
                            <field name="target_external_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="legacy_workflow_id" invisible="1"/>
                            <field name="legacy_djid" invisible="1"/>
                            <field name="legacy_business_id" invisible="1"/>
                            <field name="legacy_source_table" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="actor_name"/>
                            <field name="actor_legacy_user_id" invisible="1"/>
                            <field name="approved_at"/>
                            <field name="received_at"/>
                        </group>
                        <group>
                            <field name="action_classification" string="处理结果"/>
                            <field name="legacy_status" string="状态"/>
                            <field name="legacy_back_type" string="退回类型"/>
                            <field name="legacy_approval_type" string="审批类型"/>
                        </group>
                    </group>
                    <group string="流程上下文">
                        <field name="legacy_step_name" string="步骤"/>
                        <field name="legacy_template_name" string="流程模板"/>
                        <field name="approval_note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_sc_legacy_workflow_audit_search" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.search</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <search string="审批记录查询">
                <field name="actor_name"/>
                <field name="target_lane" string="业务分类"/>
                <field name="legacy_step_name" string="步骤"/>
                <group expand="0" string="分组">
                    <filter string="业务分类" name="group_target_lane" context="{'group_by': 'target_lane'}"/>
                    <filter string="处理结果" name="group_action_classification" context="{'group_by': 'action_classification'}"/>
                </group>
            </search>
        </field>
    </record>

