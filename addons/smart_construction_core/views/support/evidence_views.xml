<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_business_evidence_tree" model="ir.ui.view">
        <field name="name">sc.business.evidence.tree</field>
        <field name="model">sc.business.evidence</field>
        <field name="arch" type="xml">
            <tree string="Business Evidence" create="false" edit="false" delete="false">
                <field name="operate_time"/>
                <field name="name"/>
                <field name="evidence_type"/>
                <field name="business_model"/>
                <field name="business_id"/>
                <field name="amount"/>
                <field name="quantity"/>
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="operator_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_business_evidence_form" model="ir.ui.view">
        <field name="name">sc.business.evidence.form</field>
        <field name="model">sc.business.evidence</field>
        <field name="arch" type="xml">
            <form string="Business Evidence" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="evidence_type"/>
                            <field name="operate_time"/>
                            <field name="operator_id"/>
                        </group>
                        <group>
                            <field name="business_model"/>
                            <field name="business_id"/>
                            <field name="source_model"/>
                            <field name="source_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="amount"/>
                            <field name="quantity"/>
                        </group>
                    </group>
                    <group>
                        <field name="relation_chain" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_business_evidence" model="ir.actions.act_window">
        <field name="name">Business Evidence</field>
        <field name="res_model">sc.business.evidence</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- 迁移事实资产：只读原生页面，便于重建后核验历史业务事实 -->
    <record id="view_sc_legacy_workflow_audit_tree" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.tree</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <tree string="历史审批事实" create="false" edit="false" delete="false">
                <field name="approved_at"/>
                <field name="actor_name"/>
                <field name="action_classification"/>
                <field name="target_lane"/>
                <field name="target_model"/>
                <field name="target_external_id"/>
                <field name="legacy_source_table"/>
                <field name="legacy_workflow_id"/>
            </tree>
        </field>
    </record>
    <record id="view_sc_legacy_workflow_audit_form" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.form</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <form string="历史审批事实" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="target_lane"/>
                            <field name="target_model"/>
                            <field name="target_external_id"/>
                        </group>
                        <group>
                            <field name="legacy_workflow_id"/>
                            <field name="legacy_djid"/>
                            <field name="legacy_business_id"/>
                            <field name="legacy_source_table"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="actor_name"/>
                            <field name="actor_legacy_user_id"/>
                            <field name="approved_at"/>
                            <field name="received_at"/>
                        </group>
                        <group>
                            <field name="action_classification"/>
                            <field name="legacy_status"/>
                            <field name="legacy_back_type"/>
                            <field name="legacy_approval_type"/>
                        </group>
                    </group>
                    <group string="旧流程上下文">
                        <field name="legacy_step_name"/>
                        <field name="legacy_template_name"/>
                        <field name="approval_note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_sc_legacy_workflow_audit_search" model="ir.ui.view">
        <field name="name">sc.legacy.workflow.audit.search</field>
        <field name="model">sc.legacy.workflow.audit</field>
        <field name="arch" type="xml">
            <search string="历史审批事实">
                <field name="actor_name"/>
                <field name="target_lane"/>
                <field name="legacy_source_table"/>
                <field name="legacy_workflow_id"/>
                <group expand="0" string="分组">
                    <filter string="资产泳道" name="group_target_lane" context="{'group_by': 'target_lane'}"/>
                    <filter string="来源表" name="group_legacy_source_table" context="{'group_by': 'legacy_source_table'}"/>
                    <filter string="动作归类" name="group_action_classification" context="{'group_by': 'action_classification'}"/>
                </group>
            </search>
        </field>
    </record>

