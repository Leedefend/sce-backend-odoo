<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_financing_loan_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.financing.loan.fact.tree</field>
        <field name="model">sc.legacy.financing.loan.fact</field>
            <field name="arch" type="xml">
            <tree string="融资台账" create="0" edit="0" delete="0">
