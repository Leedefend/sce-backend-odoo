        <field name="model">sc.legacy.financing.loan.fact</field>
        <field name="arch" type="xml">
            <form string="融资台账" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="document_date"/>
                            <field name="document_no"/>
                            <field name="state_text"/>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="purpose"/>
                            <field name="note"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
