<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_payment_adjustment_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.payment.adjustment.fact.search</field>
        <field name="model">sc.legacy.payment.adjustment.fact</field>
        <field name="arch" type="xml">
            <search string="历史付款退款/调整事实">
                <field name="document_no"/>
                <field name="document_date"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="legacy_partner_name"/>
                <filter string="退款/退回" name="classification_refund" domain="[('adjustment_classification', '=', 'refund_or_return')]"/>
                <filter string="调户/内部调整" name="classification_adjustment" domain="[('adjustment_classification', '=', 'account_or_internal_adjustment')]"/>
                <filter string="负数未明语义" name="classification_unknown" domain="[('adjustment_classification', '=', 'negative_without_text_semantics')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按往来单位" name="group_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="按分类" name="group_classification" context="{'group_by': 'adjustment_classification'}"/>
                <filter string="按经营策略" name="group_operation_strategy" context="{'group_by': 'operation_strategy'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_payment_adjustment_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.payment.adjustment.fact.tree</field>
        <field name="model">sc.legacy.payment.adjustment.fact</field>
        <field name="arch" type="xml">
            <tree string="历史付款退款/调整事实" create="0" edit="0" delete="0" default_order="document_date desc, id desc">
                <field name="document_date"/>
                <field name="document_no"/>
                <field name="adjustment_classification"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="source_amount" sum="历史金额合计"/>
                <field name="absolute_amount" sum="绝对金额合计"/>
                <field name="operation_strategy"/>
                <field name="legacy_record_id"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_payment_adjustment_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.payment.adjustment.fact.form</field>
        <field name="model">sc.legacy.payment.adjustment.fact</field>
        <field name="arch" type="xml">
            <form string="历史付款退款/调整事实" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="业务事实">
                            <field name="document_date"/>
                            <field name="document_no"/>
                            <field name="adjustment_classification"/>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="operation_strategy"/>
                        </group>
                        <group string="金额">
                            <field name="source_amount"/>
                            <field name="absolute_amount"/>
                            <field name="currency_id"/>
                            <field name="legacy_document_state"/>
                            <field name="import_batch"/>
                        </group>
                    </group>
                    <group string="旧库来源">
                        <group>
                            <field name="legacy_source_model"/>
                            <field name="legacy_source_table"/>
                            <field name="legacy_record_id"/>
                            <field name="legacy_pid"/>
                        </group>
                        <group>
                            <field name="legacy_project_id"/>
                            <field name="legacy_project_name"/>
                            <field name="legacy_partner_id"/>
                            <field name="legacy_partner_name"/>
                        </group>
                    </group>
                    <group>
                        <field name="source_note"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_payment_adjustment_fact" model="ir.actions.act_window">
        <field name="name">历史付款退款/调整事实</field>
        <field name="res_model">sc.legacy.payment.adjustment.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_payment_adjustment_fact_search"/>
        <field name="context">{'create': False, 'search_default_group_classification': 1}</field>
        <field name="groups_id" eval="[(4, ref('smart_construction_core.group_sc_cap_finance_read')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_user')),
                                       (4, ref('smart_construction_core.group_sc_cap_finance_manager'))]"/>
    </record>

    <menuitem id="menu_sc_legacy_payment_adjustment_fact"
              name="历史付款退款/调整"
              parent="smart_construction_core.menu_sc_finance_center"
              action="action_sc_legacy_payment_adjustment_fact"
              sequence="90"
              groups="smart_construction_core.group_sc_cap_finance_read,smart_construction_core.group_sc_cap_finance_user,smart_construction_core.group_sc_cap_finance_manager"/>
</odoo>
