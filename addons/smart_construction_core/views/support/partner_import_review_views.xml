<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_sc_partner_import_review_search" model="ir.ui.view">
            <field name="name">sc.partner.import.review.search</field>
            <field name="model">sc.partner.import.review</field>
            <field name="arch" type="xml">
                <search string="客户供应商导入复核">
                    <field name="partner_name"/>
                    <field name="legacy_partner_id"/>
                    <field name="vat"/>
                    <field name="gate_reason"/>
                    <filter string="待复核" name="state_candidate" domain="[('review_state', '=', 'candidate')]"/>
                    <filter string="已处理" name="state_resolved" domain="[('review_state', '=', 'resolved')]"/>
                    <filter string="忽略" name="state_ignored" domain="[('review_state', '=', 'ignored')]"/>
                    <filter string="角色不明确" name="reason_unknown_role" domain="[('review_reason', '=', 'unknown_business_role')]"/>
                    <filter string="个人片段" name="reason_personal" domain="[('review_reason', '=', 'personal_fragment_review')]"/>
                    <filter string="按状态" name="group_state" context="{'group_by': 'review_state'}"/>
                    <filter string="按原因" name="group_reason" context="{'group_by': 'review_reason'}"/>
                    <filter string="按类型" name="group_company_type" context="{'group_by': 'company_type'}"/>
                </search>
            </field>
        </record>

        <record id="view_sc_partner_import_review_tree" model="ir.ui.view">
            <field name="name">sc.partner.import.review.tree</field>
            <field name="model">sc.partner.import.review</field>
            <field name="arch" type="xml">
                <tree string="客户供应商导入复核" default_order="review_state, review_reason, partner_name">
                    <field name="review_state"/>
                    <field name="review_reason"/>
                    <field name="partner_name"/>
                    <field name="company_type"/>
                    <field name="suggested_customer_rank"/>
                    <field name="suggested_supplier_rank"/>
                    <field name="sc_supplier_type"/>
                    <field name="vat"/>
                    <field name="sc_bank_name"/>
                    <field name="sc_bank_account"/>
                    <field name="gate_reason"/>
                    <field name="target_partner_id"/>
                </tree>
            </field>
        </record>

        <record id="view_sc_partner_import_review_form" model="ir.ui.view">
            <field name="name">sc.partner.import.review.form</field>
            <field name="model">sc.partner.import.review</field>
            <field name="arch" type="xml">
                <form string="客户供应商导入复核">
                    <header>
                        <button name="action_resolve_customer" string="确认为客户" type="object" class="oe_highlight" invisible="review_state != 'candidate'"/>
                        <button name="action_resolve_supplier" string="确认为供应商" type="object" invisible="review_state != 'candidate'"/>
                        <button name="action_resolve_customer_supplier" string="确认为客户+供应商" type="object" invisible="review_state != 'candidate'"/>
                        <button name="action_ignore" string="忽略" type="object" invisible="review_state == 'ignored'"/>
                        <field name="review_state" widget="statusbar" statusbar_visible="candidate,resolved,ignored"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="partner_name"/>
                                <field name="company_type"/>
                                <field name="review_reason"/>
                                <field name="gate_reason"/>
                            </group>
                            <group>
                                <field name="suggested_customer_rank"/>
                                <field name="suggested_supplier_rank"/>
                                <field name="confirmed_customer_rank"/>
                                <field name="confirmed_supplier_rank"/>
                                <field name="target_partner_id"/>
                            </group>
                        </group>
                        <group string="基础事实">
                            <group>
                                <field name="vat"/>
                                <field name="sc_supplier_type"/>
                                <field name="sc_region"/>
                                <field name="street"/>
                                <field name="sc_registered_capital"/>
                                <field name="sc_default_tax_rate"/>
                                <field name="sc_default_tax_rate_text"/>
                                <field name="sc_account_name"/>
                                <field name="sc_bank_name"/>
                                <field name="sc_bank_account"/>
                            </group>
                            <group>
                                <field name="legacy_partner_source"/>
                                <field name="legacy_partner_id"/>
                                <field name="import_batch"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="来源">
                                <group>
                                    <field name="source_created_by"/>
                                    <field name="source_created_at"/>
                                    <field name="source_document_state"/>
                                    <field name="source_push_result"/>
                                </group>
                                <field name="source_project_name"/>
                                <field name="source_files"/>
                                <field name="review_flags"/>
                                <field name="evidence"/>
                            </page>
                            <page string="经营范围">
                                <field name="sc_business_scope"/>
                            </page>
                            <page string="处理记录">
                                <group>
                                    <field name="reviewer_id" readonly="1"/>
                                    <field name="reviewed_at" readonly="1"/>
                                </group>
                                <field name="note"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_sc_partner_import_review" model="ir.actions.act_window">
            <field name="name">客户供应商导入复核</field>
            <field name="res_model">sc.partner.import.review</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_sc_partner_import_review_search"/>
            <field name="context">{'search_default_state_candidate': 1, 'search_default_group_reason': 1}</field>
            <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
        </record>

        <menuitem id="menu_sc_partner_import_review"
                  name="客户供应商导入复核"
                  parent="smart_construction_core.menu_sc_data_center"
                  action="action_sc_partner_import_review"
                  sequence="20"
                  groups="smart_construction_core.group_sc_cap_config_admin"/>
        <record id="menu_sc_partner_import_review" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
        </record>
    </data>
</odoo>
