<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_sc_legacy_direct_acceptance_fact_search" model="ir.ui.view">
    <field name="name">sc.legacy.direct.acceptance.fact.search</field>
    <field name="model">sc.legacy.direct.acceptance.fact</field>
    <field name="arch" type="xml">
      <search string="直营项目验收">
        <field name="acceptance_label"/>
        <field name="document_no"/>
        <field name="document_title"/>
        <field name="project_name"/>
        <field name="partner_name"/>
        <field name="creator_name"/>
        <filter string="有效" name="active_rows" domain="[('active', '=', True)]"/>
        <filter string="按菜单" name="group_acceptance_label" context="{'group_by': 'acceptance_label'}"/>
        <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
      </search>
    </field>
  </record>

  <record id="view_sc_legacy_direct_acceptance_fact_tree" model="ir.ui.view">
    <field name="name">sc.legacy.direct.acceptance.fact.tree</field>
    <field name="model">sc.legacy.direct.acceptance.fact</field>
    <field name="arch" type="xml">
      <tree string="直营项目验收" create="false" edit="false" delete="false">
        <field name="document_date"/>
        <field name="document_no"/>
        <field name="acceptance_label"/>
        <field name="project_id"/>
        <field name="project_name" optional="hide"/>
        <field name="document_title"/>
        <field name="partner_name"/>
        <field name="amount_total" sum="金额合计"/>
        <field name="quantity" sum="数量合计"/>
        <field name="document_state"/>
        <field name="creator_name"/>
        <field name="created_time"/>
      </tree>
    </field>
  </record>

