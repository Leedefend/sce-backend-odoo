<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_invoice_analysis_report_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.analysis.report.fact.search</field>
        <field name="model">sc.legacy.invoice.analysis.report.fact</field>
        <field name="arch" type="xml">
            <search string="历史发票分析报表事实">
                <field name="project_id"/>
                <field name="legacy_project_name"/>
                <field name="fact_type"/>
                <field name="invoice_company_type"/>
                <field name="legacy_source_table"/>
                <filter string="施工合同金额" name="contract_amount" domain="[('fact_type', '=', 'contract_amount')]"/>
                <filter string="进项发票金额" name="input_invoice_amount" domain="[('fact_type', '=', 'input_invoice_amount')]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按事实类型" name="group_fact_type" context="{'group_by': 'fact_type'}"/>
                <filter string="按发票公司类型" name="group_invoice_company_type" context="{'group_by': 'invoice_company_type'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_invoice_analysis_report_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.analysis.report.fact.tree</field>
        <field name="model">sc.legacy.invoice.analysis.report.fact</field>
        <field name="arch" type="xml">
            <tree string="历史发票分析报表事实" create="false" edit="false" delete="false">
                <field name="project_id"/>
                <field name="legacy_project_name"/>
                <field name="fact_type"/>
                <field name="invoice_company_type"/>
                <field name="source_amount" sum="金额合计"/>
                <field name="source_amount_field"/>
                <field name="legacy_source_table"/>
                <field name="legacy_record_id"/>
                <field name="import_batch"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_invoice_analysis_report_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.analysis.report.fact.form</field>
        <field name="model">sc.legacy.invoice.analysis.report.fact</field>
        <field name="arch" type="xml">
            <form string="历史发票分析报表事实" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="legacy_project_id"/>
                            <field name="legacy_project_name"/>
                            <field name="fact_type"/>
                        </group>
                        <group>
                            <field name="invoice_company_type"/>
                            <field name="source_amount"/>
                            <field name="source_amount_field"/>
                            <field name="import_batch"/>
                        </group>
                    </group>
                    <group string="来源">
                        <field name="legacy_source_table"/>
                        <field name="legacy_record_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_invoice_analysis_report_fact" model="ir.actions.act_window">
        <field name="name">历史发票分析报表事实</field>
        <field name="res_model">sc.legacy.invoice.analysis.report.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_invoice_analysis_report_fact_search"/>
    </record>

    <record id="view_sc_legacy_invoice_cost_progress_report_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.cost.progress.report.fact.search</field>
        <field name="model">sc.legacy.invoice.cost.progress.report.fact</field>
        <field name="arch" type="xml">
            <search string="历史发票成本进度报表事实">
                <field name="project_id"/>
                <field name="legacy_project_name"/>
                <filter string="有工程进度收款" name="has_progress_receipt" domain="[('progress_receipt_amount', '!=', 0)]"/>
                <filter string="有开票登记" name="has_output_invoice" domain="[('output_invoice_amount', '!=', 0)]"/>
                <filter string="有进项上报" name="has_input_invoice" domain="[('input_invoice_amount', '!=', 0)]"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_invoice_cost_progress_report_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.cost.progress.report.fact.tree</field>
        <field name="model">sc.legacy.invoice.cost.progress.report.fact</field>
        <field name="arch" type="xml">
            <tree string="历史发票成本进度报表事实" create="false" edit="false" delete="false">
                <field name="project_id"/>
                <field name="legacy_project_name"/>
                <field name="progress_receipt_amount" sum="工程进度收款合计"/>
                <field name="output_invoice_amount" sum="开票登记金额合计"/>
                <field name="input_invoice_amount" sum="进项上报金额合计"/>
                <field name="cost_difference_amount" sum="成本差额合计"/>
                <field name="import_batch"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_invoice_cost_progress_report_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.invoice.cost.progress.report.fact.form</field>
        <field name="model">sc.legacy.invoice.cost.progress.report.fact</field>
        <field name="arch" type="xml">
            <form string="历史发票成本进度报表事实" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="legacy_project_id"/>
                            <field name="legacy_project_name"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="progress_receipt_amount"/>
                            <field name="output_invoice_amount"/>
                            <field name="input_invoice_amount"/>
                            <field name="cost_difference_amount"/>
                            <field name="import_batch"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_invoice_cost_progress_report_fact" model="ir.actions.act_window">
        <field name="name">历史发票成本进度报表事实</field>
        <field name="res_model">sc.legacy.invoice.cost.progress.report.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_invoice_cost_progress_report_fact_search"/>
    </record>
</odoo>
