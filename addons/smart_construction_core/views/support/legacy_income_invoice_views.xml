<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sc_legacy_income_invoice_fact_search" model="ir.ui.view">
        <field name="name">sc.legacy.income.invoice.fact.search</field>
        <field name="model">sc.legacy.income.invoice.fact</field>
        <field name="arch" type="xml">
            <search string="历史收入票据事实">
                <field name="document_no"/>
                <field name="project_id"/>
                <field name="project_name"/>
                <field name="partner_name"/>
                <field name="contract_no"/>
                <field name="invoice_no"/>
                <field name="invoice_content"/>
                <field name="source_table"/>
                <filter string="有效" name="active_only" domain="[('active', '=', True)]"/>
                <filter string="有项目锚点" name="with_project" domain="[('project_id', '!=', False)]"/>
                <filter string="有金额" name="with_amount" domain="[('amount_total', '!=', 0)]"/>
                <filter string="开票申请" name="invoice_application" domain="[('fact_type', 'in', ['invoice_application', 'invoice_application_line'])]"/>
                <filter string="预缴税款" name="prepaid_tax" domain="[('fact_type', 'in', ['prepaid_tax', 'prepaid_tax_line'])]"/>
                <filter string="发票开具" name="invoice_issue" domain="[('fact_type', 'in', ['invoice_issue', 'invoice_issue_line'])]"/>
                <filter string="抵扣/转出" name="deduction" domain="[('fact_type', 'in', ['tax_deduction', 'tax_transfer_line'])]"/>
                <filter string="按事实类型" name="group_fact_type" context="{'group_by': 'fact_type'}"/>
                <filter string="按项目" name="group_project" context="{'group_by': 'project_id'}"/>
                <filter string="按客户" name="group_partner_name" context="{'group_by': 'partner_name'}"/>
                <filter string="按来源表" name="group_source_table" context="{'group_by': 'source_table'}"/>
            </search>
        </field>
    </record>

    <record id="view_sc_legacy_income_invoice_fact_tree" model="ir.ui.view">
        <field name="name">sc.legacy.income.invoice.fact.tree</field>
        <field name="model">sc.legacy.income.invoice.fact</field>
        <field name="arch" type="xml">
            <tree string="历史收入票据事实" create="0" edit="0" delete="0">
                <field name="document_date"/>
                <field name="fact_type"/>
                <field name="document_no"/>
                <field name="invoice_no"/>
                <field name="project_id"/>
                <field name="project_name"/>
                <field name="partner_name"/>
                <field name="contract_no"/>
                <field name="invoice_type"/>
                <field name="invoice_content"/>
                <field name="amount_total" sum="价税合计"/>
                <field name="amount_no_tax" sum="不含税合计"/>
                <field name="tax_amount" sum="税额合计"/>
                <field name="source_table"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sc_legacy_income_invoice_fact_form" model="ir.ui.view">
        <field name="name">sc.legacy.income.invoice.fact.form</field>
        <field name="model">sc.legacy.income.invoice.fact</field>
        <field name="arch" type="xml">
            <form string="历史收入票据事实" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="state" readonly="1"/>
                            <field name="fact_type"/>
                            <field name="source_table"/>
                            <field name="source_dataset"/>
                            <field name="document_no"/>
                            <field name="document_state"/>
                        </group>
                        <group>
                            <field name="project_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="project_legacy_id"/>
                            <field name="project_name"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="合同与客户">
                        <group>
                            <field name="partner_legacy_id"/>
                            <field name="partner_name"/>
                            <field name="partner_tax_no"/>
                            <field name="contract_legacy_id"/>
                        </group>
                        <group>
                            <field name="contract_no"/>
                            <field name="contract_name"/>
                            <field name="invoice_type"/>
                            <field name="tax_method"/>
                        </group>
                    </group>
                    <group string="发票">
                        <group>
                            <field name="invoice_no"/>
                            <field name="invoice_code"/>
                            <field name="invoice_content"/>
                        </group>
                        <group>
                            <field name="document_date"/>
                            <field name="invoice_date"/>
                            <field name="expected_receipt_date"/>
                        </group>
                    </group>
                    <group string="金额">
                        <group>
                            <field name="qty"/>
                            <field name="unit_price"/>
                            <field name="amount_total"/>
                            <field name="amount_no_tax"/>
                        </group>
                        <group>
                            <field name="tax_amount"/>
                            <field name="tax_rate"/>
                            <field name="amount_contract"/>
                            <field name="amount_received"/>
                        </group>
                    </group>
                    <group string="来源与账户">
                        <group>
                            <field name="legacy_record_id"/>
                            <field name="legacy_parent_id"/>
                            <field name="legacy_pid"/>
                            <field name="attachment_ref"/>
                        </group>
                        <group>
                            <field name="bank_name"/>
                            <field name="bank_account"/>
                            <field name="creator_name"/>
                            <field name="creator_legacy_user_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sc_legacy_income_invoice_fact" model="ir.actions.act_window">
        <field name="name">历史收入票据事实</field>
        <field name="res_model">sc.legacy.income.invoice.fact</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sc_legacy_income_invoice_fact_search"/>
        <field name="context">{'search_default_active_only': 1, 'search_default_group_fact_type': 1}</field>
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>

    <menuitem id="menu_sc_legacy_income_invoice_fact"
              name="历史收入票据事实"
              parent="smart_construction_core.menu_sc_invoice_management_group"
              action="smart_construction_core.action_sc_legacy_income_invoice_fact"
              sequence="48"
              groups="smart_construction_core.group_sc_cap_config_admin"/>
    <record id="menu_sc_legacy_income_invoice_fact" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('smart_construction_core.group_sc_cap_config_admin')])]"/>
    </record>
</odoo>
