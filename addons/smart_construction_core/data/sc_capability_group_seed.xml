<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="0">
        <!-- Keep core ownership xmlids materialized for fresh-runtime install order.
             Scene module may update these records with smart_construction_core.* ids. -->
        <record id="sc_cap_group_project_management" model="sc.capability.group">
            <field name="sequence">10</field>
            <field name="key">project_management</field>
            <field name="label">项目管理</field>
            <field name="icon">briefcase</field>
        </record>
        <record id="sc_cap_group_contract_management" model="sc.capability.group">
            <field name="sequence">20</field>
            <field name="key">contract_management</field>
            <field name="label">合同管理</field>
            <field name="icon">file-text</field>
        </record>
        <record id="sc_cap_group_cost_management" model="sc.capability.group">
            <field name="sequence">30</field>
            <field name="key">cost_management</field>
            <field name="label">成本管理</field>
            <field name="icon">calculator</field>
        </record>
        <record id="sc_cap_group_finance_management" model="sc.capability.group">
            <field name="sequence">40</field>
            <field name="key">finance_management</field>
            <field name="label">财务管理</field>
            <field name="icon">wallet</field>
        </record>
        <record id="sc_cap_group_material_management" model="sc.capability.group">
            <field name="sequence">50</field>
            <field name="key">material_management</field>
            <field name="label">物资管理</field>
            <field name="icon">boxes</field>
        </record>
        <record id="sc_cap_group_governance" model="sc.capability.group">
            <field name="sequence">60</field>
            <field name="key">governance</field>
            <field name="label">治理配置</field>
            <field name="icon">shield</field>
        </record>
        <record id="sc_cap_group_analytics" model="sc.capability.group">
            <field name="sequence">70</field>
            <field name="key">analytics</field>
            <field name="label">经营分析</field>
            <field name="icon">chart</field>
        </record>
        <record id="sc_cap_group_others" model="sc.capability.group">
            <field name="sequence">80</field>
            <field name="key">others</field>
            <field name="label">其他能力</field>
            <field name="icon">grid</field>
        </record>

        <record id="sc_cap_project_work" model="sc.capability">
            <field name="sequence">10</field>
            <field name="key">project.board.open</field>
            <field name="name">项目工作</field>
            <field name="group_id" ref="sc_cap_group_project_management"/>
            <field name="ui_label">项目工作</field>
            <field name="ui_hint">项目看板与概览入口</field>
            <field name="intent">ui.contract</field>
            <field name="default_payload" eval="{'action_xmlid': 'smart_construction_core.action_sc_project_kanban_lifecycle', 'menu_xmlid': 'smart_construction_core.menu_sc_project_project'}"/>
            <field name="tags">project</field>
            <field name="status">ga</field>
        </record>
        <record id="sc_cap_capability_matrix" model="sc.capability">
            <field name="sequence">20</field>
            <field name="key">governance.capability.matrix</field>
            <field name="name">能力矩阵</field>
            <field name="group_id" ref="sc_cap_group_governance"/>
            <field name="ui_label">能力矩阵</field>
            <field name="ui_hint">查看角色可用能力</field>
            <field name="intent">ui.contract</field>
            <field name="default_payload" eval="{'action_xmlid': 'smart_construction_portal.action_sc_portal_capability_matrix', 'menu_xmlid': 'smart_construction_portal.menu_sc_portal_capability_matrix'}"/>
            <field name="tags">portal,capability</field>
            <field name="status">ga</field>
        </record>
        <record id="sc_cap_contract_work" model="sc.capability">
            <field name="sequence">30</field>
            <field name="key">contract.center.open</field>
            <field name="name">合同中心</field>
            <field name="group_id" ref="sc_cap_group_contract_management"/>
            <field name="ui_label">合同中心</field>
            <field name="ui_hint">合同台账、进度与收款跟踪</field>
            <field name="intent">ui.contract</field>
            <field name="default_payload" eval="{'action_xmlid': 'smart_construction_core.action_construction_contract_my', 'menu_xmlid': 'smart_construction_core.menu_sc_contract_income'}"/>
            <field name="tags">contract,workspace</field>
            <field name="status">ga</field>
        </record>
        <record id="sc_cap_cost_work" model="sc.capability">
            <field name="sequence">40</field>
            <field name="key">cost.analysis.open</field>
            <field name="name">成本工作台</field>
            <field name="group_id" ref="sc_cap_group_cost_management"/>
            <field name="ui_label">成本工作台</field>
            <field name="ui_hint">成本台账、预算与执行跟踪</field>
            <field name="intent">ui.contract</field>
            <field name="default_payload" eval="{'action_xmlid': 'smart_construction_core.action_project_cost_ledger_my', 'menu_xmlid': 'smart_construction_core.menu_sc_project_cost_ledger'}"/>
            <field name="tags">cost,workspace</field>
            <field name="status">ga</field>
        </record>
        <record id="sc_cap_finance_work" model="sc.capability">
            <field name="sequence">50</field>
            <field name="key">finance.workspace.open</field>
            <field name="name">资金工作台</field>
            <field name="group_id" ref="sc_cap_group_finance_management"/>
            <field name="ui_label">资金工作台</field>
            <field name="ui_hint">付款申请、支付台账与结算单</field>
            <field name="intent">ui.contract</field>
            <field name="default_payload" eval="{'action_xmlid': 'smart_construction_core.action_payment_request_my', 'menu_xmlid': 'smart_construction_core.menu_payment_request'}"/>
            <field name="tags">finance,workspace</field>
            <field name="status">ga</field>
        </record>

        <record id="sc_scene_default" model="sc.scene">
            <field name="sequence">1</field>
            <field name="name">默认工作台</field>
            <field name="code">default.dashboard</field>
            <field name="layout">grid</field>
            <field name="state">published</field>
            <field name="version">v2</field>
        </record>
    </data>
</odoo>
