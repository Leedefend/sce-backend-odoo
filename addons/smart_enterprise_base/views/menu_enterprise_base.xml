<odoo>
    <record id="action_enterprise_company" model="ir.actions.act_window">
        <field name="name">公司信息</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="smart_enterprise_base.view_company_tree_enterprise_base"/>
        <field name="search_view_id" ref="smart_enterprise_base.view_company_search_enterprise_base"/>
        <field name="context">{'form_view_ref': 'smart_enterprise_base.view_company_form_enterprise_base'}</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        <field name="help" type="html">
            <p>从这里统一创建和维护公司信息，后续组织、用户、项目都归属到公司。</p>
            <p>建议先完成公司保存，再点击公司内的“组织架构”进入下一步。</p>
        </field>
    </record>

    <record id="action_enterprise_company_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="smart_enterprise_base.view_company_tree_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_company"/>
    </record>

    <record id="action_enterprise_company_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="smart_enterprise_base.view_company_form_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_company"/>
    </record>

    <record id="action_enterprise_department" model="ir.actions.act_window">
        <field name="name">组织架构</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="smart_enterprise_base.view_department_tree_enterprise_base"/>
        <field name="search_view_id" ref="smart_enterprise_base.view_department_search_enterprise_base"/>
        <field name="context">{'form_view_ref': 'smart_enterprise_base.view_department_form_enterprise_base'}</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        <field name="help" type="html">
            <p>从这里统一维护组织架构，所有部门都必须归属到公司。</p>
            <p>推荐路径：先创建一级部门，再继续补二级、三级部门，最后进入用户设置。</p>
        </field>
    </record>

    <record id="action_enterprise_department_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="smart_enterprise_base.view_department_tree_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_department"/>
    </record>

    <record id="action_enterprise_department_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="smart_enterprise_base.view_department_form_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_department"/>
    </record>

    <record id="action_enterprise_user" model="ir.actions.act_window">
        <field name="name">用户设置</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="smart_enterprise_base.view_users_tree_enterprise_base"/>
        <field name="search_view_id" ref="smart_enterprise_base.view_users_search_enterprise_base"/>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        <field name="context">{'active_test': False, 'no_reset_password': True, 'form_view_ref': 'smart_enterprise_base.view_users_form_enterprise_base'}</field>
        <field name="help" type="html">
            <p>从这里统一维护用户主数据，让公司、组织和负责人关系真正落到人。</p>
            <p>本页只承接基础资料，不替代角色、安全和高级权限原生页面。</p>
            <p>本页现在由业务系统管理员与平台管理员共同持有，但仍不承接平台治理字段。</p>
        </field>
    </record>

    <record id="action_enterprise_user_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="smart_enterprise_base.view_users_tree_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_user"/>
    </record>

    <record id="action_enterprise_user_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="smart_enterprise_base.view_users_form_enterprise_base"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_user"/>
    </record>

    <record id="view_enterprise_post_tree" model="ir.ui.view">
        <field name="name">sc.enterprise.post.tree.enterprise.base</field>
        <field name="model">sc.enterprise.post</field>
        <field name="arch" type="xml">
            <tree string="岗位管理" default_order="company_id, sequence, name">
                <field name="name" string="岗位名称"/>
                <field name="code" string="岗位编码"/>
                <field name="company_id" string="所属公司"/>
                <field name="sequence" string="排序"/>
                <field name="sc_user_count" string="用户数"/>
                <field name="active" string="启用"/>
            </tree>
        </field>
    </record>

    <record id="view_enterprise_post_form" model="ir.ui.view">
        <field name="name">sc.enterprise.post.form.enterprise.base</field>
        <field name="model">sc.enterprise.post</field>
        <field name="arch" type="xml">
            <form string="岗位管理">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        这里只维护企业岗位主数据。岗位独立于部门和系统角色，当前系统仅支持一个主岗位。
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_enterprise_users"
                                class="oe_stat_button"
                                icon="fa-users"
                                string="用户设置">
                            <field name="sc_user_count" widget="statinfo" string="用户数"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_enterprise_post_search" model="ir.ui.view">
        <field name="name">sc.enterprise.post.search.enterprise.base</field>
        <field name="model">sc.enterprise.post</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="岗位名称"/>
                <field name="code" string="岗位编码"/>
                <field name="company_id" string="所属公司"/>
                <filter name="sc_enterprise_post_active_true" string="启用中" domain="[('active', '=', True)]"/>
                <filter name="sc_enterprise_post_active_false" string="已停用" domain="[('active', '=', False)]"/>
                <group expand="0" string="分组">
                    <filter name="group_by_company_id" string="所属公司" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_enterprise_post" model="ir.actions.act_window">
        <field name="name">岗位管理</field>
        <field name="res_model">sc.enterprise.post</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="smart_enterprise_base.view_enterprise_post_tree"/>
        <field name="search_view_id" ref="smart_enterprise_base.view_enterprise_post_search"/>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
        <field name="context">{'form_view_ref': 'smart_enterprise_base.view_enterprise_post_form'}</field>
        <field name="help" type="html">
            <p>从这里统一维护企业岗位主数据，用于承接用户主岗位。</p>
            <p>岗位不替代组织架构，也不替代系统角色。</p>
        </field>
    </record>

    <record id="action_enterprise_post_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="smart_enterprise_base.view_enterprise_post_tree"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_post"/>
    </record>

    <record id="action_enterprise_post_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="smart_enterprise_base.view_enterprise_post_form"/>
        <field name="act_window_id" ref="smart_enterprise_base.action_enterprise_post"/>
    </record>

    <menuitem id="menu_enterprise_base_root"
              name="企业启用"
              sequence="35"
              groups="base.group_system"/>

    <menuitem id="menu_enterprise_company"
              name="公司管理"
              parent="menu_enterprise_base_root"
              action="action_enterprise_company"
              sequence="10"
              groups="base.group_system"/>

    <menuitem id="menu_enterprise_department"
              name="组织架构"
              parent="menu_enterprise_base_root"
              action="action_enterprise_department"
              sequence="20"
              groups="base.group_system"/>

    <menuitem id="menu_enterprise_post"
              name="岗位管理"
              parent="menu_enterprise_base_root"
              action="action_enterprise_post"
              sequence="25"
              groups="base.group_system"/>

    <menuitem id="menu_enterprise_user"
              name="用户设置"
              parent="menu_enterprise_base_root"
              action="action_enterprise_user"
              sequence="30"
              groups="base.group_system"/>
</odoo>
