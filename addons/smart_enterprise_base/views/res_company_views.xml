<odoo>
    <record id="view_company_form_enterprise_base" model="ir.ui.view">
        <field name="name">res.company.form.enterprise.base</field>
        <field name="model">res.company</field>
        <field name="mode">primary</field>
        <field name="inherit_id" eval="False"/>
        <field name="arch" type="xml">
            <form string="公司信息">
                <sheet>
                    <div class="alert alert-info" role="status">
                        这里只维护企业启用所需的基础信息。保存后请继续进入“组织架构”。
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_enterprise_departments"
                                class="oe_stat_button"
                                icon="fa-sitemap"
                                string="组织架构">
                            <field name="sc_department_count" widget="statinfo" string="部门数"/>
                        </button>
                    </div>
                    <group string="企业基础信息">
                        <group>
                            <field name="name" string="公司名称" required="1"/>
                            <field name="sc_short_name" string="公司简称"/>
                            <field name="sc_credit_code" string="统一社会信用代码"/>
                        </group>
                        <group>
                            <field name="sc_contact_phone" string="联系电话"/>
                            <field name="sc_address" string="地址"/>
                            <field name="sc_is_active" string="启用"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_company_tree_enterprise_base" model="ir.ui.view">
        <field name="name">res.company.tree.enterprise.base</field>
        <field name="model">res.company</field>
        <field name="mode">primary</field>
        <field name="inherit_id" eval="False"/>
        <field name="arch" type="xml">
            <tree default_order="name">
                <field name="name"/>
                <field name="sc_short_name"/>
                <field name="sc_credit_code"/>
                <field name="sc_contact_phone"/>
                <field name="sc_address"/>
                <field name="sc_is_active"/>
            </tree>
        </field>
    </record>

    <record id="view_company_search_enterprise_base" model="ir.ui.view">
        <field name="name">res.company.search.enterprise.base</field>
        <field name="model">res.company</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="sc_short_name"/>
                <field name="sc_credit_code"/>
                <filter name="sc_company_active_true" string="启用中" domain="[('sc_is_active', '=', True)]"/>
                <filter name="sc_company_active_false" string="已停用" domain="[('sc_is_active', '=', False)]"/>
            </search>
        </field>
    </record>
</odoo>
